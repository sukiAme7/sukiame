<%
const toArray = (collection) => {
  if (!collection) return [];
  if (Array.isArray(collection)) return collection;
  if (typeof collection.toArray === 'function') return collection.toArray();
  return [];
};
const allPosts = toArray(site.posts ? site.posts.sort('date', -1) : []);
const posts = toArray(page.posts || []);
const categories = toArray(site.categories).filter((item) => item.length).sort((a, b) => b.length - a.length);
const tags = toArray(site.tags).filter((item) => item.length).sort((a, b) => b.length - a.length);
const photoWallConfig = theme.photo_wall || {};
const guestbookConfig = theme.guestbook || {};
const friendsConfig = theme.friends || {};
const resolveUrl = (value) => { const link = value || '#'; return /^(?:[a-z][a-z0-9+.-]*:)?\/\//i.test(link) || /^(#|mailto:|tel:)/i.test(link) ? link : url_for(link); };
const getEntry = (group, key) => { const source = group && group[key] ? group[key] : {}; return typeof source === 'string' ? { url: source } : source; };
const toPlainText = (value) => String(value || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
const countWords = (value) => {
  const text = toPlainText(value).replace(/&[a-z0-9#]+;/gi, ' ');
  if (!text) return 0;
  const cjkCount = (text.match(/[\u3400-\u4dbf\u4e00-\u9fff\uf900-\ufaff]/g) || []).length;
  const latinCount = text.replace(/[\u3400-\u4dbf\u4e00-\u9fff\uf900-\ufaff]/g, ' ').split(/[\s.,!?;:()[\]{}"'`~<>/@#$%^&*_+=|\\-]+/).filter(Boolean).length;
  return cjkCount + latinCount;
};
const formatCount = (value) => value >= 10000 ? `${Math.round(value / 1000)}k` : value >= 1000 ? `${(value / 1000).toFixed(1).replace(/\.0$/, '')}k` : `${value}`;
const getWordCountLabel = (post) => `${formatCount(countWords(post.content || post.excerpt || post.description || ''))} Words`;
const summarize = (post) => {
  const raw = post.description || post.excerpt || (post.content ? toPlainText(post.content) : '');
  return toPlainText(raw).slice(0, 110) || 'No preview yet.';
};
const getCover = (post) => { const photo = Array.isArray(post.photos) && post.photos.length ? post.photos[0] : ''; const raw = post.cover || post.thumbnail || post.banner || post.top_img || photo || ''; if (!raw) return ''; const value = typeof raw === 'string' ? raw : (raw.path || raw.url || ''); return value ? resolveUrl(value) : ''; };
const homeMenu = getEntry(theme.menu, 'Home');
const archiveMenu = getEntry(theme.menu, 'Archives');
const friendsMenu = getEntry(theme.menu, 'Friends');
const guestbookMenu = getEntry(theme.menu, 'Guestbook');
const dockLinks = [
  { label: homeMenu.label || 'Home', url: homeMenu.url || '/', icon: homeMenu.icon || 'fa-solid fa-house' },
  { label: archiveMenu.label || 'Blog', url: archiveMenu.url || '/archives/', icon: archiveMenu.icon || 'fa-solid fa-feather-pointed', active: true },
  friendsMenu.url && friendsMenu.url !== '#' ? { label: friendsMenu.label || friendsConfig.title || 'Friends', url: friendsMenu.url, icon: friendsMenu.icon || friendsConfig.icon || 'fa-solid fa-link' } : { label: friendsConfig.title || 'Friends', url: friendsConfig.url || '/friends/', icon: friendsConfig.icon || 'fa-solid fa-link' },
  guestbookMenu.url && guestbookMenu.url !== '#' ? { label: guestbookMenu.label || 'Guestbook', url: guestbookMenu.url, icon: guestbookMenu.icon || guestbookConfig.icon || 'fa-solid fa-message' } : null,
  photoWallConfig.url ? { label: photoWallConfig.title || 'Photo Wall', url: photoWallConfig.url, icon: photoWallConfig.icon || 'fa-solid fa-image' } : null
].filter(Boolean);
const archiveGroups = []; const archiveMap = new Map();
allPosts.forEach((post) => { const year = date(post.date, 'YYYY'); const month = date(post.date, 'MM'); const key = `${year}-${month}`; if (!archiveMap.has(key)) { const entry = { key, year, month, label: `${year}.${month}`, path: url_for(`/archives/${year}/${month}/`), count: 0 }; archiveMap.set(key, entry); archiveGroups.push(entry); } archiveMap.get(key).count += 1; });
const isCategoryPage = !!page.category; const isTagPage = !!page.tag;
let heroTitle = 'Blog'; let heroSubtitle = 'Latest writing, categories, archives and tags.'; let heroMeta = `${allPosts.length} Posts`;
if (isCategoryPage) { const match = categories.find((item) => item.name === page.category); heroTitle = `Category / ${page.category}`; heroSubtitle = 'Posts collected under this category.'; heroMeta = `${match ? match.length : posts.length} Posts`; }
else if (isTagPage) { const match = tags.find((item) => item.name === page.tag); heroTitle = `Tag / ${page.tag}`; heroSubtitle = 'Posts connected by this tag.'; heroMeta = `${match ? match.length : posts.length} Posts`; }
else if (page.year && page.month) { heroTitle = `Archive / ${page.year}.${String(page.month).padStart(2, '0')}`; heroSubtitle = 'A monthly look back through the blog.'; heroMeta = `${posts.length} Posts`; }
else if (page.year) { heroTitle = `Archive / ${page.year}`; heroSubtitle = 'Posts gathered by year.'; heroMeta = `${posts.length} Posts`; }
%>
<style>
  .blog-shell{position:relative;min-height:100vh;padding:1rem;overflow:hidden}.blog-shell::before,.blog-shell::after{content:"";position:absolute;inset:-12%;pointer-events:none}.blog-shell::before{background:radial-gradient(circle at 14% 16%,rgba(255,255,255,.6),rgba(255,255,255,0) 22%),radial-gradient(circle at 14% 84%,rgba(125,211,252,.22),rgba(125,211,252,0) 20%),radial-gradient(circle at 76% 80%,rgba(134,239,172,.22),rgba(134,239,172,0) 20%);filter:blur(18px);opacity:.96}.blog-shell::after{background:linear-gradient(180deg,rgba(255,255,255,.22),rgba(255,255,255,.08))}
  .blog-dock,.blog-status{position:absolute;z-index:20}.blog-dock{top:1rem;left:1rem;padding:.6rem .75rem;display:inline-flex;align-items:center;gap:.55rem}.blog-status{top:1rem;right:1rem;min-width:12rem;padding:.75rem .95rem;display:flex;flex-direction:column;gap:.18rem}
  .blog-status strong{font-size:.98rem;color:#1e293b;font-weight:800}.blog-status span{font-size:.76rem;color:#64748b;font-weight:700}.blog-status small{font-size:.72rem;color:#94a3b8;font-weight:700}
  .dock-avatar,.dock-link{width:2.35rem;height:2.35rem;border-radius:999px;display:inline-flex;align-items:center;justify-content:center;background:rgba(255,255,255,.66);color:#64748b;box-shadow:0 6px 18px rgba(148,163,184,.12);transition:transform .25s ease,background .25s ease,color .25s ease}
  .dock-avatar img{width:1.8rem;height:1.8rem;border-radius:999px;object-fit:cover}.dock-link:hover,.dock-avatar:hover{transform:translateY(-2px);background:rgba(255,255,255,.82)}.dock-link.is-active{background:rgba(255,255,255,.84);color:#38bdf8}
  .blog-grid{position:relative;z-index:1;width:min(1260px,100%);margin:0 auto;padding-top:5.2rem;display:grid;grid-template-columns:minmax(0,1.8fr) minmax(20rem,.92fr);gap:1.5rem;align-items:start}.blog-main,.blog-side{display:flex;flex-direction:column;gap:1.5rem}.blog-hero,.blog-panel{padding:1.35rem 1.4rem}
  .blog-kicker{font-size:.76rem;letter-spacing:.14em;text-transform:uppercase;color:#94a3b8;font-weight:800}.blog-title{margin:.65rem 0 0;font-size:clamp(1.8rem,3vw,2.45rem);line-height:1.02;color:#1e293b;font-weight:900;letter-spacing:-.03em}.blog-copy{margin:.85rem 0 0;max-width:42rem;color:#64748b;font-size:.96rem;line-height:1.8;font-weight:600}
  .blog-meta-row{margin-top:1rem;display:flex;flex-wrap:wrap;gap:.65rem}.blog-meta-pill,.blog-chip,.blog-side-link,.blog-tag-link,.blog-pager-link,.blog-pager-current{display:inline-flex;align-items:center;gap:.42rem;border-radius:999px;background:rgba(255,255,255,.56);color:#475569;box-shadow:inset 0 1px 0 rgba(255,255,255,.3)}.blog-meta-pill,.blog-chip{padding:.46rem .72rem;font-size:.75rem;font-weight:800}
  .blog-panel-head{display:flex;align-items:center;justify-content:space-between;gap:.75rem;margin-bottom:1rem}.blog-panel-title{margin:0;font-size:1rem;color:#1e293b;font-weight:900}.blog-panel-subtitle{font-size:.72rem;color:#94a3b8;font-weight:800;letter-spacing:.08em;text-transform:uppercase}.blog-list{display:grid;gap:1.55rem}.blog-side-list{display:grid;gap:.8rem}
  .blog-card{position:relative;padding:1.15rem;border-radius:1.25rem;border:1px solid rgba(255,255,255,.74);background:rgba(255,255,255,.38);box-shadow:inset 0 1px 0 rgba(255,255,255,.28),0 10px 24px rgba(148,163,184,.08);transition:transform .22s ease,background .22s ease,box-shadow .22s ease,border-color .22s ease}.blog-card:hover{transform:translateY(-3px);background:rgba(255,255,255,.5);border-color:rgba(186,230,253,.95);box-shadow:0 14px 34px rgba(148,163,184,.14)}.blog-card-cover{display:block;width:100%;aspect-ratio:16/8.6;margin:0 0 1rem;border-radius:1rem;overflow:hidden;background:linear-gradient(135deg,#bae6fd,#d9f99d)}.blog-card-cover img{width:100%;height:100%;object-fit:cover;display:block}.blog-card-head{display:flex;justify-content:space-between;align-items:flex-start;gap:1rem}.blog-card-title{margin:0;font-size:1.08rem;line-height:1.35;color:#1e293b;font-weight:900}.blog-card-date{flex:none;font-size:.74rem;color:#94a3b8;font-weight:800;letter-spacing:.08em}
  .blog-card-excerpt{margin:.78rem 0 0;color:#64748b;font-size:.9rem;line-height:1.8;font-weight:600}.blog-card-taxonomy{margin-top:.85rem;display:flex;flex-wrap:wrap;gap:.5rem}.blog-card-footer{margin-top:.95rem;display:flex;align-items:center;justify-content:space-between;gap:.8rem}.blog-card-more{display:inline-flex;align-items:center;gap:.5rem;color:#0369a1;font-size:.82rem;font-weight:900}.blog-card-wordcount{display:inline-flex;align-items:center;gap:.38rem;color:#94a3b8;font-size:.74rem;font-weight:800;letter-spacing:.04em;text-align:right;flex:none}
  .blog-side-link{justify-content:space-between;width:100%;padding:.7rem .88rem;font-size:.82rem;font-weight:800}.blog-tag-cloud{display:flex;flex-wrap:wrap;gap:.55rem}.blog-tag-link{padding:.5rem .78rem;font-size:.78rem;font-weight:800}
  .blog-chip:hover,.blog-side-link:hover,.blog-tag-link:hover,.blog-pager-link:hover{transform:translateY(-2px);background:rgba(255,255,255,.76)}.blog-chip.is-active,.blog-side-link.is-active,.blog-tag-link.is-active{background:rgba(186,230,253,.72);color:#0369a1}.blog-empty{padding:1rem 0 .2rem;color:#94a3b8;font-size:.86rem;line-height:1.8;font-weight:700}
  .blog-pager{display:flex;justify-content:space-between;align-items:center;gap:1rem;margin-top:1rem}.blog-pager-link,.blog-pager-current{min-width:7rem;padding:.7rem .95rem;font-size:.82rem;font-weight:800;justify-content:center}
  @media (max-width:1024px){.blog-grid{grid-template-columns:1fr}} @media (max-width:768px){.blog-shell{padding:1rem}.blog-dock,.blog-status{position:relative;top:auto;left:auto;right:auto;margin-bottom:.85rem}.blog-dock{width:fit-content}.blog-status{min-width:0}.blog-grid{padding-top:.2rem}} @media (max-width:640px){.blog-dock{width:100%;justify-content:space-between;gap:.4rem}.dock-avatar,.dock-link{width:2.1rem;height:2.1rem}.blog-pager{flex-direction:column}.blog-pager-link,.blog-pager-current{width:100%}}
</style>
<div class="blog-shell"><nav class="blog-dock glass-card" aria-label="Blog navigation"><a href="<%- resolveUrl(homeMenu.url || '/') %>" class="dock-avatar" aria-label="Home"><img src="<%- theme.avatar || '/images/avatar-cat.svg' %>" alt="avatar"></a><% dockLinks.forEach((item) => { %><a href="<%- resolveUrl(item.url) %>" class="dock-link <%= item.active ? 'is-active' : '' %>" aria-label="<%- item.label %>" title="<%- item.label %>"><i class="<%- item.icon %>"></i></a><% }) %></nav><section class="blog-status glass-card" aria-label="Blog summary"><strong><%- heroTitle %></strong><span><%- heroSubtitle %></span><small><%- heroMeta %></small></section><div class="blog-grid"><main class="blog-main"><section class="glass-card blog-hero"><span class="blog-kicker">Writing Space</span><h1 class="blog-title"><%- heroTitle %></h1><p class="blog-copy"><%- heroSubtitle %></p><div class="blog-meta-row"><span class="blog-meta-pill"><i class="fa-solid fa-feather-pointed"></i><%- `${allPosts.length} Total Posts` %></span><span class="blog-meta-pill"><i class="fa-solid fa-box-archive"></i><%- `${archiveGroups.length} Archives` %></span><span class="blog-meta-pill"><i class="fa-solid fa-tags"></i><%- `${tags.length} Tags` %></span></div></section><section class="glass-card blog-panel"><div class="blog-panel-head"><div><h2 class="blog-panel-title">Post List</h2><span class="blog-panel-subtitle">Recent Writing</span></div><span class="blog-panel-subtitle"><%- `${posts.length} On This Page` %></span></div><% if (!posts.length) { %><div class="blog-empty">No posts yet. Once you add new posts, they will appear here with categories, archives and tags.</div><% } else { %><div class="blog-list"><% posts.forEach((post) => { const postCategories = toArray(post.categories); const postTags = toArray(post.tags); const postCover = getCover(post); const postWordCountLabel = getWordCountLabel(post); %><article class="blog-card"><% if (postCover) { %><a href="<%- url_for(post.path) %>" class="blog-card-cover"><img src="<%- postCover %>" alt="<%- post.title %>" loading="lazy"></a><% } %><div class="blog-card-head"><h3 class="blog-card-title"><a href="<%- url_for(post.path) %>"><%- post.title %></a></h3><span class="blog-card-date"><%- date(post.date, 'YYYY.MM.DD') %></span></div><p class="blog-card-excerpt"><%- summarize(post) %></p><div class="blog-card-taxonomy"><% postCategories.forEach((item) => { %><a href="<%- url_for(item.path) %>" class="blog-chip"><i class="fa-solid fa-folder-open"></i><%- item.name %></a><% }) %><% postTags.slice(0, 3).forEach((item) => { %><a href="<%- url_for(item.path) %>" class="blog-chip"><i class="fa-solid fa-hashtag"></i><%- item.name %></a><% }) %></div><div class="blog-card-footer"><a href="<%- url_for(post.path) %>" class="blog-card-more">Read Post <i class="fa-solid fa-arrow-right"></i></a><span class="blog-card-wordcount"><i class="fa-regular fa-file-lines"></i><%- postWordCountLabel %></span></div></article><% }) %></div><% if ((page.total || 1) > 1) { %><div class="blog-pager"><% if (page.prev_link) { %><a href="<%- url_for(page.prev_link) %>" class="blog-pager-link"><i class="fa-solid fa-arrow-left"></i>&nbsp;Previous</a><% } else { %><span class="blog-pager-current">No Previous</span><% } %><span class="blog-pager-current"><%- `Page ${page.current || 1} / ${page.total || 1}` %></span><% if (page.next_link) { %><a href="<%- url_for(page.next_link) %>" class="blog-pager-link">Next&nbsp;<i class="fa-solid fa-arrow-right"></i></a><% } else { %><span class="blog-pager-current">No Next</span><% } %></div><% } %><% } %></section></main><aside class="blog-side"><section class="glass-card blog-panel"><div class="blog-panel-head"><div><h2 class="blog-panel-title">Categories</h2><span class="blog-panel-subtitle">Folder View</span></div></div><% if (!categories.length) { %><div class="blog-empty">No categories yet. Add `categories:` in post front matter to see them here.</div><% } else { %><div class="blog-side-list"><% categories.forEach((item) => { %><a href="<%- url_for(item.path) %>" class="blog-side-link <%= isCategoryPage && page.category === item.name ? 'is-active' : '' %>"><span><i class="fa-solid fa-folder-tree"></i>&nbsp;<%- item.name %></span><span><%- item.length %></span></a><% }) %></div><% } %></section><section class="glass-card blog-panel"><div class="blog-panel-head"><div><h2 class="blog-panel-title">Archives</h2><span class="blog-panel-subtitle">Monthly Map</span></div></div><% if (!archiveGroups.length) { %><div class="blog-empty">No archive data yet.</div><% } else { %><div class="blog-side-list"><% archiveGroups.slice(0, 10).forEach((item) => { const activeArchive = page.year && page.month && String(page.year) === item.year && String(page.month).padStart(2, '0') === item.month; %><a href="<%- item.path %>" class="blog-side-link <%= activeArchive ? 'is-active' : '' %>"><span><i class="fa-regular fa-calendar"></i>&nbsp;<%- item.label %></span><span><%- item.count %></span></a><% }) %></div><% } %></section><section class="glass-card blog-panel"><div class="blog-panel-head"><div><h2 class="blog-panel-title">Tags</h2><span class="blog-panel-subtitle">Topic Cloud</span></div></div><% if (!tags.length) { %><div class="blog-empty">No tags yet. Add `tags:` in post front matter to build this cloud.</div><% } else { %><div class="blog-tag-cloud"><% tags.forEach((item) => { %><a href="<%- url_for(item.path) %>" class="blog-tag-link <%= isTagPage && page.tag === item.name ? 'is-active' : '' %>"><i class="fa-solid fa-hashtag"></i><%- item.name %><span><%- item.length %></span></a><% }) %></div><% } %></section></aside></div></div>





<%
const friendsConfig = theme.friends || {};
const pageTitle = friendsConfig.page_title || friendsConfig.title || page.title || 'Friends';
const pageSubtitle = friendsConfig.page_subtitle || friendsConfig.subtitle || 'Gentle Corners Of The Web';
const pageIcon = friendsConfig.icon || 'fa-solid fa-link';
const pageNote = friendsConfig.note || 'A few lovely places worth keeping close.';
const countLabel = friendsConfig.count_label || 'Sites';
const exchangeTitle = friendsConfig.exchange_title || 'Link Exchange';
const exchangeCopy = friendsConfig.exchange_copy || 'If your site has its own style and a little warmth, I would love to exchange links.';
const exchangeRules = Array.isArray(friendsConfig.exchange_rules) ? friendsConfig.exchange_rules : [];
const resolveUrl = (value) => { const link = value || '#'; return /^(?:[a-z][a-z0-9+.-]*:)?\/\//i.test(link) || /^(#|mailto:|tel:)/i.test(link) ? link : url_for(link); };
const getEntry = (group, key) => { const source = group && group[key] ? group[key] : {}; return typeof source === 'string' ? { url: source } : source; };
const homeMenu = getEntry(theme.menu, 'Home');
const archiveMenu = getEntry(theme.menu, 'Archives');
const guestbookMenu = getEntry(theme.menu, 'Guestbook');
const photoWallConfig = theme.photo_wall || {};
const emailSocial = getEntry(theme.social, 'Email');
const accentPalette = { blue: { tint: 'rgba(186, 230, 253, 0.85)', text: '#0369a1', glow: 'rgba(56, 189, 248, 0.18)' }, pink: { tint: 'rgba(251, 207, 232, 0.85)', text: '#be185d', glow: 'rgba(244, 114, 182, 0.18)' }, green: { tint: 'rgba(220, 252, 231, 0.85)', text: '#15803d', glow: 'rgba(74, 222, 128, 0.18)' }, peach: { tint: 'rgba(254, 215, 170, 0.85)', text: '#c2410c', glow: 'rgba(251, 146, 60, 0.18)' }, lavender: { tint: 'rgba(233, 213, 255, 0.85)', text: '#7c3aed', glow: 'rgba(168, 85, 247, 0.18)' } };
const defaultItems = [ { name: 'Paper Rain', url: 'https://example.com', avatar: 'https://api.dicebear.com/9.x/glass/svg?seed=paper-rain', description: 'Small essays, frontend sketches, and soft web experiments.', tags: ['Blog', 'Coding'], accent: 'blue' }, { name: 'Cloud Notes', url: 'https://example.com', avatar: 'https://api.dicebear.com/9.x/glass/svg?seed=cloud-notes', description: 'Essays, design fragments, and soft digital diaries.', tags: ['Essays', 'Design'], accent: 'lavender' }, { name: 'Mint Lab', url: 'https://example.com', avatar: 'https://api.dicebear.com/9.x/glass/svg?seed=mint-lab', description: 'A calm lab for frontend tinkering, tiny widgets, and UI drafts.', tags: ['Frontend', 'UI'], accent: 'green' }, { name: 'Night Shelf', url: 'https://example.com', avatar: 'https://api.dicebear.com/9.x/glass/svg?seed=night-shelf', description: 'Reading logs, favorite quotes, and a shelf of long-form notes.', tags: ['Reading', 'Notes'], accent: 'peach' }, { name: 'Pixel Harbor', url: 'https://example.com', avatar: 'https://api.dicebear.com/9.x/glass/svg?seed=pixel-harbor', description: 'Illustration studies, game screenshots, and visual journaling.', tags: ['Art', 'Visual'], accent: 'pink' } ];
const rawItems = Array.isArray(friendsConfig.items) && friendsConfig.items.length ? friendsConfig.items : defaultItems;
const friendItems = rawItems.map((item, index) => { const accentKey = accentPalette[item.accent] ? item.accent : Object.keys(accentPalette)[index % Object.keys(accentPalette).length]; const accent = accentPalette[accentKey]; return { name: item.name || `Friend ${index + 1}`, url: resolveUrl(item.url || '#'), avatar: item.avatar ? resolveUrl(item.avatar) : '', description: item.description || 'A lovely place on the web.', tags: Array.isArray(item.tags) ? item.tags : [], accent }; });
const dockLinks = [ { label: homeMenu.label || 'Home', url: homeMenu.url || '/', icon: homeMenu.icon || 'fa-solid fa-house' }, { label: archiveMenu.label || 'Blog', url: archiveMenu.url || '/archives/', icon: archiveMenu.icon || 'fa-solid fa-feather-pointed' }, photoWallConfig.url ? { label: photoWallConfig.title || 'Photo Wall', url: photoWallConfig.url, icon: photoWallConfig.icon || 'fa-solid fa-image' } : null, guestbookMenu.url && guestbookMenu.url !== '#' ? { label: guestbookMenu.label || 'Guestbook', url: guestbookMenu.url, icon: guestbookMenu.icon || 'fa-solid fa-message' } : null, { label: pageTitle, url: friendsConfig.url || '/friends/', icon: pageIcon, active: true } ].filter(Boolean);
%>
<style>
  .friends-shell{position:relative;min-height:100vh;padding:1rem;overflow:hidden}.friends-shell::before,.friends-shell::after{content:"";position:absolute;inset:-12%;pointer-events:none}.friends-shell::before{background:radial-gradient(circle at 14% 16%,rgba(255,255,255,.62),rgba(255,255,255,0) 22%),radial-gradient(circle at 14% 84%,rgba(125,211,252,.22),rgba(125,211,252,0) 20%),radial-gradient(circle at 76% 80%,rgba(134,239,172,.22),rgba(134,239,172,0) 20%),radial-gradient(circle at 86% 20%,rgba(251,207,232,.18),rgba(251,207,232,0) 18%);filter:blur(18px);opacity:.96}.friends-shell::after{background:linear-gradient(180deg,rgba(255,255,255,.22),rgba(255,255,255,.08))}
  .friends-dock,.friends-status{position:absolute;z-index:20}.friends-dock{top:1rem;left:1rem;padding:.6rem .75rem;display:inline-flex;align-items:center;gap:.55rem}.friends-status{top:1rem;right:1rem;min-width:12rem;padding:.75rem .95rem;display:flex;flex-direction:column;gap:.18rem}.friends-status strong{font-size:.98rem;color:#1e293b;font-weight:800}.friends-status span{font-size:.76rem;color:#64748b;font-weight:700}.friends-status small{font-size:.72rem;color:#94a3b8;font-weight:700}
  .dock-avatar,.dock-link{width:2.35rem;height:2.35rem;border-radius:999px;display:inline-flex;align-items:center;justify-content:center;background:rgba(255,255,255,.66);color:#64748b;box-shadow:0 6px 18px rgba(148,163,184,.12);transition:transform .25s ease,background .25s ease,color .25s ease}.dock-avatar img{width:1.8rem;height:1.8rem;border-radius:999px;object-fit:cover}.dock-link:hover,.dock-avatar:hover{transform:translateY(-2px);background:rgba(255,255,255,.82)}.dock-link.is-active{background:rgba(255,255,255,.84);color:#38bdf8}
  .friends-grid{position:relative;z-index:1;width:min(1320px,100%);margin:0 auto;padding-top:5.2rem;display:grid;grid-template-columns:minmax(0,1.9fr) minmax(18rem,.72fr);gap:1.5rem;align-items:start}.friends-main,.friends-side{display:flex;flex-direction:column;gap:1.5rem}.friends-hero,.friends-panel{padding:1.4rem 1.45rem}
  .friends-kicker{font-size:.76rem;letter-spacing:.14em;text-transform:uppercase;color:#94a3b8;font-weight:800}.friends-title{margin:.65rem 0 0;font-size:clamp(1.9rem,3vw,2.5rem);line-height:1.04;color:#1e293b;font-weight:900;letter-spacing:-.03em}.friends-copy{margin:.85rem 0 0;max-width:40rem;color:#64748b;font-size:.95rem;line-height:1.8;font-weight:600}
  .friends-meta{margin-top:1rem;display:flex;flex-wrap:wrap;gap:.65rem}.friends-pill,.friend-tag,.friends-rule,.friends-cta{display:inline-flex;align-items:center;gap:.42rem;border-radius:999px;background:rgba(255,255,255,.56);color:#475569;box-shadow:inset 0 1px 0 rgba(255,255,255,.3)}.friends-pill,.friend-tag{padding:.46rem .72rem;font-size:.76rem;font-weight:800}
  .friends-panel-head{display:flex;align-items:center;justify-content:space-between;gap:.75rem;margin-bottom:1rem}.friends-panel-title{margin:0;font-size:1rem;color:#1e293b;font-weight:900}.friends-panel-subtitle{font-size:.72rem;color:#94a3b8;font-weight:800;letter-spacing:.08em;text-transform:uppercase}
  .friends-list{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:.9rem}.friend-card{position:relative;padding:.92rem .92rem .88rem;border-radius:1.2rem;border:1px solid rgba(255,255,255,.68);background:rgba(255,255,255,.38);box-shadow:inset 0 1px 0 rgba(255,255,255,.28),0 10px 26px rgba(148,163,184,.1);transition:transform .22s ease,background .22s ease,box-shadow .22s ease}.friend-card::after{content:"";position:absolute;inset:0;border-radius:inherit;background:radial-gradient(circle at 100% 0,var(--friend-glow),transparent 48%);pointer-events:none}.friend-card:hover{transform:translateY(-3px);background:rgba(255,255,255,.5);box-shadow:0 16px 34px rgba(148,163,184,.14)}
  .friend-head{display:flex;align-items:center;gap:.78rem}.friend-avatar{width:3rem;height:3rem;border-radius:1rem;overflow:hidden;flex-shrink:0;background:linear-gradient(135deg,#bae6fd,#d9f99d);box-shadow:0 8px 18px rgba(148,163,184,.12)}.friend-avatar img{width:100%;height:100%;object-fit:cover;display:block}.friend-name{margin:0;font-size:.98rem;color:#1e293b;font-weight:900;line-height:1.2}
  .friend-desc{margin:.72rem 0 0;color:#64748b;font-size:.86rem;line-height:1.72;font-weight:600;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}.friend-tags{margin-top:.72rem;display:flex;flex-wrap:wrap;gap:.42rem}.friend-tag{background:var(--friend-tint);color:var(--friend-text)}.friend-foot{margin-top:.82rem;display:flex;justify-content:space-between;align-items:center;gap:.8rem}.friend-link{display:inline-flex;align-items:center;gap:.45rem;padding:.52rem .82rem;border-radius:999px;background:rgba(255,255,255,.74);color:#1e293b;font-size:.78rem;font-weight:900;box-shadow:0 10px 24px rgba(148,163,184,.12);transition:transform .2s ease,background .2s ease}.friend-link:hover{transform:translateY(-2px);background:#fff}.friend-pulse{width:.58rem;height:.58rem;border-radius:999px;background:var(--friend-text);box-shadow:0 0 0 .22rem var(--friend-tint)}
  .friends-note{color:#94a3b8;font-size:.84rem;line-height:1.8;font-weight:700}.friends-exchange-copy{margin:0;color:#64748b;font-size:.92rem;line-height:1.85;font-weight:600}.friends-rules{margin-top:1rem;display:grid;gap:.6rem}.friends-rule{justify-content:flex-start;padding:.62rem .78rem;font-size:.8rem;font-weight:800}.friends-cta-wrap{margin-top:1rem;display:flex;flex-wrap:wrap;gap:.6rem}.friends-cta{padding:.62rem .9rem;font-size:.8rem;font-weight:900}.friends-empty{padding:.8rem 0 0;color:#94a3b8;font-size:.86rem;line-height:1.8;font-weight:700}
  @media (max-width:1180px){.friends-grid{grid-template-columns:1fr}.friends-list{grid-template-columns:repeat(2,minmax(0,1fr))}} @media (max-width:768px){.friends-shell{padding:1rem}.friends-dock,.friends-status{position:relative;top:auto;left:auto;right:auto;margin-bottom:.85rem}.friends-dock{width:fit-content}.friends-grid{padding-top:.2rem}} @media (max-width:640px){.friends-dock{width:100%;justify-content:space-between;gap:.4rem}.dock-avatar,.dock-link{width:2.1rem;height:2.1rem}.friends-list{grid-template-columns:1fr}}
</style>
<div class="friends-shell"><nav class="friends-dock glass-card" aria-label="Friends navigation"><a href="<%- resolveUrl(homeMenu.url || '/') %>" class="dock-avatar" aria-label="Home"><img src="<%- theme.avatar || '/images/avatar-cat.svg' %>" alt="avatar"></a><% dockLinks.forEach((item) => { %><a href="<%- resolveUrl(item.url) %>" class="dock-link <%= item.active ? 'is-active' : '' %>" aria-label="<%- item.label %>" title="<%- item.label %>"><i class="<%- item.icon %>"></i></a><% }) %></nav><section class="friends-status glass-card" aria-label="Friends summary"><strong><%- pageTitle %></strong><span><%- pageSubtitle %></span><small><%- `${friendItems.length} ${countLabel}` %></small></section><div class="friends-grid"><main class="friends-main"><section class="glass-card friends-hero"><span class="friends-kicker">Friend Links</span><h1 class="friends-title"><%- pageTitle %></h1><p class="friends-copy"><%- pageNote %></p><div class="friends-meta"><span class="friends-pill"><i class="fa-solid fa-link"></i><%- `${friendItems.length} Linked Sites` %></span><span class="friends-pill"><i class="fa-solid fa-heart"></i>Indie Web</span><span class="friends-pill"><i class="fa-solid fa-sparkles"></i>Same Theme, Different Stories</span></div></section><section class="glass-card friends-panel"><div class="friends-panel-head"><div><h2 class="friends-panel-title">Friend Cards</h2><span class="friends-panel-subtitle">Curated Links</span></div><span class="friends-panel-subtitle"><%- `${friendItems.length} Listed` %></span></div><% if (!friendItems.length) { %><div class="friends-empty">No friend links yet. Add entries under `friends.items` in your theme config to populate this page.</div><% } else { %><div class="friends-list"><% friendItems.forEach((item) => { %><article class="friend-card" style="--friend-tint: <%- item.accent.tint %>; --friend-text: <%- item.accent.text %>; --friend-glow: <%- item.accent.glow %>;"><div class="friend-head"><div class="friend-avatar"><% if (item.avatar) { %><img src="<%- item.avatar %>" alt="<%- item.name %>" loading="lazy"><% } %></div><div><h3 class="friend-name"><%- item.name %></h3></div></div><p class="friend-desc"><%- item.description %></p><div class="friend-tags"><% item.tags.forEach((tag) => { %><span class="friend-tag"><i class="fa-solid fa-hashtag"></i><%- tag %></span><% }) %></div><div class="friend-foot"><span class="friend-pulse" aria-hidden="true"></span><a class="friend-link" href="<%- item.url %>" target="_blank" rel="noopener">Visit Site <i class="fa-solid fa-arrow-up-right-from-square"></i></a></div></article><% }) %></div><% } %></section></main><aside class="friends-side"><section class="glass-card friends-panel"><div class="friends-panel-head"><div><h2 class="friends-panel-title"><%- exchangeTitle %></h2><span class="friends-panel-subtitle">How To Join</span></div></div><p class="friends-exchange-copy"><%- exchangeCopy %></p><div class="friends-rules"><% exchangeRules.forEach((rule) => { %><div class="friends-rule"><i class="fa-solid fa-paperclip"></i><%- rule %></div><% }) %></div><div class="friends-cta-wrap"><% if (emailSocial.url) { %><a href="<%- emailSocial.url %>" class="friends-cta"><i class="fa-solid fa-envelope"></i>Contact By Email</a><% } %><a href="<%- resolveUrl(homeMenu.url || '/') %>" class="friends-cta"><i class="fa-solid fa-house"></i>Back Home</a></div></section></aside></div></div>

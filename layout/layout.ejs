<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%- page.title || config.title %></title>
    <link rel="icon" href="<%- /^(?:[a-z][a-z0-9+.-]*:)?\/\//i.test(theme.favicon || theme.avatar || '') ? (theme.favicon || theme.avatar) : url_for(theme.favicon || theme.avatar || '/images/avatar-cat.svg') %>">
    <link rel="alternate" type="application/atom+xml" title="<%- config.title || 'RSS Feed' %>" href="<%- url_for('/atom.xml') %>">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="<%- url_for('/vendor/katex/katex.min.css') %>">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=ZCOOL+KuaiLe&display=swap" rel="stylesheet">
    <script>
        (() => {
            try {
                const raw = window.sessionStorage.getItem('sukiame-page-transition');
                if (!raw) return;

                const snapshot = JSON.parse(raw);
                if (
                    snapshot &&
                    snapshot.href === window.location.href &&
                    Date.now() - snapshot.at < 4000
                ) {
                    document.documentElement.classList.add('is-page-enter-prep');
                }
            } catch (error) {}
        })();
    </script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Nunito', 'sans-serif'],
                        cute: ['ZCOOL KuaiLe', 'cursive'],
                    },
                    colors: {
                        'rain-light': '#e0f2fe',
                        'rain-blue': '#7dd3fc',
                        'rain-dark': '#0369a1',
                    }
                }
            }
        }
    </script>
    <style>
        :root {
            --card-bg: rgba(255, 255, 255, 0.4);
            --card-bg-hover: rgba(255, 255, 255, 0.55);
            --card-border: rgba(255, 255, 255, 0.8);
            --text-main: #334155;
            --text-soft: #64748b;
            --text-muted: #94a3b8;
            --rain-blue: #7dd3fc;
            --rain-dark: #0369a1;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(-45deg, #e0f2fe, #bae6fd, #f3e8ff, #e0e7ff);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
            color: var(--text-main);
            font-family: 'Nunito', sans-serif;
        }

        body::after {
            content: "";
            position: fixed;
            inset: 0;
            background:
                radial-gradient(circle at 18% 22%, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0) 28%),
                radial-gradient(circle at 82% 18%, rgba(186, 230, 253, 0.24), rgba(186, 230, 253, 0) 26%),
                linear-gradient(135deg, rgba(224, 242, 254, 0.2), rgba(243, 232, 255, 0.18));
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.64s cubic-bezier(0.2, 0.76, 0.2, 1);
            z-index: 999;
        }

        body.is-page-leaving::after {
            opacity: 1;
        }

        body.is-page-leaving {
            pointer-events: none;
        }

        .page-transition-target {
            will-change: transform, opacity;
            transform-origin: center center;
            backface-visibility: hidden;
            transform-style: preserve-3d;
            contain: paint;
            isolation: isolate;
            --page-exit-duration: 1060ms;
            --page-enter-duration: 620ms;
            --page-transition-delay: 0ms;
            --page-exit-scale: 0.88;
        }

        body.is-page-leaving .page-transition-target {
            animation: pageTransitionOut var(--page-exit-duration) cubic-bezier(0.2, 0.74, 0.18, 1) both;
            animation-delay: var(--page-transition-delay);
            pointer-events: none;
        }

        html.is-page-entering .page-transition-target {
            animation: pageTransitionIn var(--page-enter-duration) cubic-bezier(0.14, 0.82, 0.2, 1) both;
            animation-delay: var(--page-transition-delay);
            pointer-events: none;
        }

        html.is-page-enter-prep .page-transition-target {
            opacity: 0;
            transform: translate3d(var(--page-enter-x, 0px), var(--page-enter-y, 0px), 0) scale(0.972) rotate(var(--page-enter-rotate, 0deg));
            pointer-events: none;
        }

        html.is-page-enter-prep .profile-panel,
        html.is-page-enter-prep .nav-panel,
        html.is-page-enter-prep .hero-panel,
        html.is-page-enter-prep .latest-panel,
        html.is-page-enter-prep .photo-panel,
        html.is-page-enter-prep .activity-panel,
        html.is-page-enter-prep .clock-panel,
        html.is-page-enter-prep .calendar-panel,
        html.is-page-enter-prep .visitors-panel,
        html.is-page-enter-prep .blog-dock,
        html.is-page-enter-prep .blog-status,
        html.is-page-enter-prep .blog-hero,
        html.is-page-enter-prep .blog-panel,
        html.is-page-enter-prep .post-dock,
        html.is-page-enter-prep .post-status,
        html.is-page-enter-prep .post-hero,
        html.is-page-enter-prep .post-panel,
        html.is-page-enter-prep .friends-dock,
        html.is-page-enter-prep .friends-status,
        html.is-page-enter-prep .friends-hero,
        html.is-page-enter-prep .friends-panel,
        html.is-page-enter-prep .photo-wall-dock,
        html.is-page-enter-prep .photo-wall-status,
        html.is-page-enter-prep .photo-wall-board,
        html.is-page-enter-prep .guestbook-dock,
        html.is-page-enter-prep .guestbook-status,
        html.is-page-enter-prep .guestbook-board {
            opacity: 0;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        @keyframes pageTransitionOut {
            0% {
                opacity: 1;
                transform: translate3d(0, 0, 0) scale(1) rotate(0deg);
            }

            32% {
                opacity: 0.997;
                transform: translate3d(calc(var(--page-exit-mid-x, 0px) * 0.4), calc(var(--page-exit-mid-y, 0px) * 0.4), 0) scale(0.995) rotate(calc(var(--page-exit-mid-rotate, 0deg) * 0.48));
            }

            70% {
                opacity: 0.952;
                transform: translate3d(var(--page-exit-mid-x, 0px), var(--page-exit-mid-y, 0px), 0) scale(0.986) rotate(var(--page-exit-mid-rotate, 0deg));
            }

            100% {
                opacity: 0;
                transform: translate3d(var(--page-exit-x, 0px), var(--page-exit-y, 0px), 0) scale(var(--page-exit-scale, 0.88)) rotate(var(--page-exit-rotate, 0deg));
            }
        }

        @keyframes pageTransitionIn {
            0% {
                opacity: 0;
                transform: translate3d(var(--page-enter-x, 0px), var(--page-enter-y, 0px), 0) scale(0.972) rotate(var(--page-enter-rotate, 0deg));
            }

            68% {
                opacity: 0.99;
                transform: translate3d(calc(var(--page-enter-x, 0px) * 0.14), calc(var(--page-enter-y, 0px) * 0.14), 0) scale(0.997) rotate(calc(var(--page-enter-rotate, 0deg) * 0.14));
            }

            100% {
                opacity: 1;
                transform: translate3d(0, 0, 0) scale(1) rotate(0deg);
            }
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        button {
            border: 0;
            background: transparent;
            cursor: pointer;
            font: inherit;
        }

        .home-shell {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
            position: relative;
            overflow-x: hidden;
        }

        .home-grid {
            width: min(1350px, 100%);
            display: grid;
            grid-template-columns: repeat(12, minmax(0, 1fr));
            gap: 2rem;
            align-items: start;
            margin: auto 0;
            position: relative;
            z-index: 1;
        }

        .left-column,
        .center-column,
        .right-column {
            display: flex;
            flex-direction: column;
            gap: 1.75rem;
        }

        .right-column {
            gap: 1rem;
            align-self: start;
            justify-content: flex-start;
            height: calc(310px + 1.75rem + 330px);
        }

        .left-column { grid-column: span 3 / span 3; }
        .center-column { grid-column: span 6 / span 6; }
        .right-column { grid-column: span 3 / span 3; }

        .glass-card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--card-border);
            border-right: 1px solid rgba(255, 255, 255, 0.4);
            border-bottom: 1px solid rgba(255, 255, 255, 0.4);
            border-radius: 1.5rem;
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.04);
            transition: all 0.3s ease;
        }

        .glass-card:hover {
            background: var(--card-bg-hover);
            box-shadow: 0 12px 40px 0 rgba(31, 38, 135, 0.08);
            transform: translateY(-2px);
        }

        .profile-panel {
            min-height: 310px;
            padding: 2rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .profile-avatar-box {
            position: relative;
            width: 6rem;
            height: 6rem;
            margin-bottom: 1.25rem;
            cursor: pointer;
        }

        .profile-avatar {
            width: 100%;
            height: 100%;
            border-radius: 999px;
            object-fit: cover;
            border: 3px solid #fff;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.12);
        }

        .profile-status {
            position: absolute;
            right: 0;
            bottom: 0;
            width: 1.25rem;
            height: 1.25rem;
            border-radius: 999px;
            background: #4ade80;
            border: 2px solid #fff;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.08);
        }

        .profile-title {
            margin: 0;
            font-size: 2rem;
            line-height: 1;
            color: #1e293b;
            letter-spacing: 0.03em;
        }

        .profile-subtitle {
            margin: 0.75rem 0 0;
            font-size: 13px;
            color: #64748b;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.375rem;
        }

        .profile-actions {
            width: 100%;
            display: flex;
            justify-content: center;
            gap: 1rem;
            margin-top: 1.25rem;
        }

        .profile-actions a {
            width: 2.25rem;
            height: 2.25rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.6);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #64748b;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.06);
            transition: all 0.25s ease;
        }

        .profile-actions a:hover {
            background: #fff;
            transform: translateY(-4px);
        }

        .nav-panel {
            position: relative;
            overflow: hidden;
            min-height: 330px;
            padding: 1.5rem 1.25rem;
            display: flex;
            flex-direction: column;
        }

        .nav-panel-icon {
            position: absolute;
            top: -1.5rem;
            right: -1.5rem;
            font-size: 5.5rem;
            color: rgba(255, 255, 255, 0.3);
            pointer-events: none;
        }

        .section-kicker {
            margin: 0 0 1.25rem;
            padding-left: 0.5rem;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #94a3b8;
            position: relative;
            z-index: 1;
        }

        .nav-links {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .nav-link {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.875rem;
            border-radius: 0.875rem;
            color: #64748b;
            transition: all 0.25s ease;
        }

        .nav-link:hover {
            background: rgba(255, 255, 255, 0.6);
            color: #1e293b;
        }

        .active-nav {
            background: #fff;
            border-left: 4px solid #0369a1;
            border-radius: 6px 14px 14px 6px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
            color: #0369a1;
        }

        .nav-link-label {
            display: flex;
            align-items: center;
            gap: 1rem;
            font-size: 15px;
            font-weight: 700;
        }

        .nav-link-label i {
            width: 1.5rem;
            text-align: center;
            font-size: 1.125rem;
        }

        .nav-link-arrow {
            color: #94a3b8;
            font-size: 0.875rem;
            transition: color 0.25s ease;
        }

        .nav-link:hover .nav-link-arrow {
            color: #334155;
        }

        .nav-link-arrow-fade {
            opacity: 0;
            transition: opacity 0.25s ease;
        }

        .nav-link:hover .nav-link-arrow-fade {
            opacity: 1;
        }

        .hero-panel {
            min-height: 310px;
            padding: 2.5rem;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .hero-illustration {
            position: absolute;
            right: -1rem;
            bottom: -1rem;
            font-size: 13rem;
            color: rgba(255, 255, 255, 0.4);
            pointer-events: none;
            transition: transform 0.7s ease;
        }

        .hero-panel:hover .hero-illustration {
            transform: scale(1.1);
        }

        .hero-content {
            position: relative;
            z-index: 1;
        }

        .hero-greeting {
            margin: 0 0 0.5rem;
            font-size: 1.25rem;
            color: #64748b;
            font-weight: 700;
        }

        .hero-title {
            margin: 0 0 1rem;
            font-size: clamp(2.5rem, 6vw, 3.5rem);
            line-height: 1.1;
            font-weight: 900;
            color: #1e293b;
        }

        .hero-name {
            background: linear-gradient(to right, #0369a1, #3b82f6, #8b5cf6);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: 0.05em;
            padding-bottom: 0.125rem;
        }

        .hero-copy {
            margin: 0;
            max-width: 34rem;
            padding-left: 1rem;
            border-left: 4px solid #7dd3fc;
            color: #64748b;
            font-size: 1rem;
            line-height: 1.75;
            font-weight: 600;
        }

        .hero-copy-text {
            margin: 0;
        }

        .hero-copy-source {
            display: block;
            margin-top: 0.15rem;
            text-align: right;
            font-size: 0.92rem;
            color: #7b8798;
        }

        .center-bottom-grid {
            min-height: 330px;
            display: grid;
            grid-template-columns: repeat(5, minmax(0, 1fr));
            gap: 1.75rem;
        }

        .latest-panel {
            grid-column: span 3 / span 3;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            min-height: 330px;
        }

        .panel-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.25rem;
        }

        .panel-title {
            margin: 0;
            font-size: 15px;
            font-weight: 800;
            color: #334155;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .panel-title-bar {
            width: 0.25rem;
            height: 1rem;
            border-radius: 999px;
            background: #7dd3fc;
        }

        .panel-link {
            font-size: 10px;
            color: #94a3b8;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .post-list {
            display: flex;
            flex-direction: column;
            gap: 0.625rem;
        }

        .post-row {
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            padding: 0.75rem;
            border-radius: 0.75rem;
            transition: background 0.25s ease;
        }

        .post-row:hover {
            background: rgba(255, 255, 255, 0.6);
        }

        .post-icon {
            width: 3rem;
            height: 3rem;
            border-radius: 0.75rem;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }

        .post-cover-thumb {
            width: 3rem;
            height: 3rem;
            border-radius: 0.75rem;
            overflow: hidden;
            flex-shrink: 0;
            box-shadow: 0 8px 20px rgba(148, 163, 184, 0.16);
            background: linear-gradient(135deg, #bae6fd, #d9f99d);
        }

        .post-cover-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.28s ease;
        }

        .post-row:hover .post-cover-thumb img {
            transform: scale(1.06);
        }

        .post-row:hover .post-icon {
            color: #fff;
        }

        .post-icon-blue {
            background: rgba(239, 246, 255, 0.8);
            color: #3b82f6;
        }

        .post-row:hover .post-icon-blue {
            background: #3b82f6;
        }

        .post-icon-green {
            background: rgba(240, 253, 244, 0.8);
            color: #22c55e;
        }

        .post-row:hover .post-icon-green {
            background: #22c55e;
        }

        .post-icon-purple {
            background: rgba(245, 243, 255, 0.8);
            color: #a855f7;
        }

        .post-row:hover .post-icon-purple {
            background: #a855f7;
        }

        .post-text {
            min-width: 0;
            flex: 1;
            padding-top: 0.125rem;
        }

        .post-title {
            margin: 0 0 0.25rem;
            font-size: 0.875rem;
            font-weight: 700;
            color: #334155;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .post-excerpt {
            margin: 0;
            font-size: 11px;
            color: #64748b;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .post-date {
            flex-shrink: 0;
            font-size: 10px;
            font-weight: 700;
            color: #94a3b8;
            padding-top: 0.375rem;
        }

        .side-stack {
            grid-column: span 2 / span 2;
            min-height: 330px;
            display: flex;
            flex-direction: column;
            gap: 1.75rem;
        }

        .photo-panel,
        .activity-panel {
            min-height: 140px;
            padding: 1.25rem;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .photo-panel {
            min-height: 152px;
            padding: 1.25rem 1.15rem 1.05rem;
            align-items: flex-start;
            justify-content: flex-start;
            text-align: left;
            background: var(--card-bg);
            border-color: var(--card-border);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.04);
        }

        .photo-panel::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0) 58%);
            pointer-events: none;
        }

        .photo-panel:hover {
            background: var(--card-bg-hover);
            box-shadow: 0 12px 40px 0 rgba(31, 38, 135, 0.08);
        }

        .photo-glow,
        .activity-glow {
            position: absolute;
            right: -20px;
            bottom: -20px;
            width: 6rem;
            height: 6rem;
            border-radius: 999px;
            filter: blur(32px);
            opacity: 0.4;
            transition: opacity 0.25s ease, transform 0.35s ease;
            pointer-events: none;
        }

        .photo-glow {
            top: -2.4rem;
            right: -0.8rem;
            bottom: auto;
            width: 8rem;
            height: 8rem;
            background: radial-gradient(circle, rgba(125, 211, 252, 0.3) 0%, rgba(224, 242, 254, 0.22) 42%, rgba(255, 255, 255, 0) 72%);
            filter: blur(18px);
            opacity: 0.72;
        }

        .activity-glow {
            background: linear-gradient(to bottom right, #5eead4, #d1fae5);
        }

        .photo-panel:hover .photo-glow,
        .activity-panel:hover .activity-glow {
            opacity: 0.8;
        }

        .photo-panel:hover .photo-glow {
            opacity: 1;
            transform: scale(1.06);
        }

        .photo-copy,
        .activity-head {
            position: relative;
            z-index: 1;
        }

        .photo-copy h3,
        .activity-head h3 {
            margin: 0;
            font-size: 1rem;
            font-weight: 800;
            color: #1e293b;
        }

        .photo-copy p,
        .activity-head p {
            margin: 0.25rem 0 0;
            font-size: 11px;
            color: #64748b;
            font-weight: 600;
        }

        .photo-stack {
            position: absolute;
            left: 1.15rem;
            bottom: 0.6rem;
            width: 8.9rem;
            height: 5.95rem;
            z-index: 1;
            pointer-events: none;
            transform: none;
            transform-origin: bottom left;
        }

        .photo-shot {
            position: absolute;
            background: #fff;
            padding: 0.18rem 0.18rem 0.46rem;
            border-radius: 0.8rem;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.75);
            box-shadow: 0 12px 24px rgba(79, 98, 140, 0.22);
            z-index: 0;
            transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s ease;
        }

        .photo-shot img {
            position: relative;
            z-index: 1;
            width: 100%;
            height: calc(100% - 0.08rem);
            object-fit: cover;
            display: block;
            border-radius: 0.5rem;
        }

        .photo-shot-label {
            position: absolute;
            left: 0.28rem;
            right: 0.28rem;
            bottom: 0.12rem;
            z-index: 2;
            text-align: center;
            font-size: 0.56rem;
            line-height: 1;
            color: #475569;
            font-weight: 800;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .photo-shot::before,
        .photo-shot::after {
            content: "";
            position: absolute;
            inset: 0.18rem 0.18rem 0.46rem;
            border-radius: 0.5rem;
        }

        .photo-shot::after {
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0) 48%);
        }

        .photo-shot.has-image::before {
            display: none;
        }

        .photo-shot-one::before {
            background:
                radial-gradient(circle at 62% 26%, rgba(255, 230, 182, 0.95), rgba(255, 230, 182, 0) 16%),
                linear-gradient(180deg, rgba(18, 32, 70, 0.12) 0%, rgba(18, 32, 70, 0) 18%),
                linear-gradient(180deg, #1e2a4c 0%, #314a79 48%, #ea8b72 100%);
        }

        .photo-shot-two::before {
            background:
                radial-gradient(circle at 50% 24%, rgba(221, 242, 248, 0.9), rgba(221, 242, 248, 0) 22%),
                linear-gradient(180deg, rgba(255, 255, 255, 0.14) 0%, rgba(255, 255, 255, 0) 20%),
                linear-gradient(180deg, #2f4d5d 0%, #416f76 54%, #98b8b0 100%);
        }

        .photo-shot-one {
            left: 0.05rem;
            bottom: 0.3rem;
            width: 3.85rem;
            height: 4.8rem;
            transform: rotate(-11deg);
            z-index: 2;
        }

        .photo-shot-two {
            left: 4.2rem;
            bottom: 0;
            width: 3.85rem;
            height: 4.8rem;
            transform: rotate(12deg);
            z-index: 1;
        }

        .photo-panel:hover .photo-shot-one {
            transform: rotate(-15deg) translateY(-3px) scale(1.03);
            box-shadow: 0 14px 24px rgba(79, 98, 140, 0.24);
        }

        .photo-panel:hover .photo-shot-two {
            transform: rotate(15deg) translate(5px, -3px) scale(1.03);
            box-shadow: 0 12px 22px rgba(79, 98, 140, 0.2);
        }

        .photo-badge {
            width: 2.75rem;
            height: 2.75rem;
            border-radius: 1rem;
            background: rgba(255, 255, 255, 0.7);
            color: #3b82f6;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 22px rgba(59, 130, 246, 0.1);
            position: absolute;
            top: 1.25rem;
            right: 1rem;
            z-index: 2;
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

        .photo-panel:hover .photo-badge {
            transform: translateY(-2px) scale(1.04);
            box-shadow: 0 12px 24px rgba(59, 130, 246, 0.14);
        }

        .photo-badge i {
            font-size: 1rem;
        }

        .photo-copy {
            width: 100%;
            max-width: none;
            padding-right: 4.6rem;
        }

        .photo-copy h3 {
            font-size: 1.08rem;
            line-height: 1.15;
            font-weight: 800;
            letter-spacing: -0.01em;
            color: #1e293b;
        }

        .photo-copy p {
            margin-top: 0.3rem;
            font-size: 0.72rem;
            color: #64748b;
            font-weight: 600;
        }

        .activity-panel {
            align-items: stretch;
            justify-content: flex-start;
        }

        .activity-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 1rem;
        }

        .activity-head p {
            margin-top: 0.2rem;
        }

        .activity-icon {
            color: #f87171;
            font-size: 1.15rem;
            margin-top: 0.15rem;
        }

        .activity-grid {
            position: relative;
            z-index: 1;
            display: grid;
            grid-auto-flow: column;
            grid-template-rows: repeat(2, 0.72rem);
            grid-auto-columns: 0.72rem;
            gap: 0.55rem 0.42rem;
            margin-top: auto;
            justify-content: start;
        }

        .activity-cell {
            width: 0.72rem;
            height: 0.72rem;
            border-radius: 0.16rem;
            background: rgba(241, 245, 249, 0.78);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.45);
        }

        .activity-cell.level-0 { background: rgba(235, 237, 240, 0.95); }
        .activity-cell.level-1 { background: #9be9a8; }
        .activity-cell.level-2 { background: #40c463; }
        .activity-cell.level-3 { background: #30a14e; }

        .clock-panel,
        .calendar-panel {
            flex-shrink: 0;
        }

        .clock-panel {
            min-height: 118px;
            padding: 1.25rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .clock-display {
            display: flex;
            align-items: baseline;
            justify-content: center;
            gap: 0.5rem;
        }

        .clock-display span {
            font-size: 3rem;
            font-weight: 900;
            color: #334155;
            letter-spacing: -0.04em;
        }

        .clock-separator {
            font-size: 1.875rem;
            color: #93c5fd;
            position: relative;
            top: -0.25rem;
            animation: pulse 2s ease-in-out infinite;
        }

        .clock-meta {
            margin-top: 0.75rem;
            font-size: 10px;
            font-weight: 800;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #94a3b8;
        }

        .calendar-panel {
            flex: 1;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            min-height: 398px;
        }

        .calendar-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.25rem;
        }

        .calendar-month {
            font-size: 0.875rem;
            font-weight: 900;
            color: #334155;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }

        .calendar-arrows {
            display: flex;
            gap: 0.375rem;
        }

        .calendar-arrow {
            width: 1.5rem;
            height: 1.5rem;
            border-radius: 0.375rem;
            background: rgba(255, 255, 255, 0.6);
            color: #94a3b8;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.06);
            transition: all 0.25s ease;
        }

        .calendar-arrow:hover {
            color: #334155;
            background: #fff;
        }

        .calendar-weekdays,
        .calendar-days {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            text-align: center;
            font-size: 11px;
        }

        .calendar-weekdays {
            gap: 0.25rem;
            margin-bottom: 0.35rem;
        }

        .calendar-weekday {
            font-weight: 700;
            color: #94a3b8;
            margin-bottom: 0.25rem;
        }

        .calendar-weekday.is-sun { color: #f472b6; font-weight: 900; }
        .calendar-weekday.is-sat { color: #60a5fa; font-weight: 900; }

        .calendar-days {
            gap: 0.34rem 0.18rem;
            min-height: 298px;
        }

        .calendar-day {
            aspect-ratio: 1 / 1;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
            color: #475569;
            border-radius: 0.625rem;
            transition: color 0.25s ease, box-shadow 0.25s ease;
        }

        .calendar-day:hover {
            color: #0369a1;
        }

        .calendar-day.is-muted {
            color: #cbd5e1;
            font-weight: 500;
        }

        .calendar-day.is-today {
            background: linear-gradient(to bottom right, #60a5fa, #6366f1);
            color: #fff;
            font-weight: 900;
            box-shadow: 0 8px 18px rgba(99, 102, 241, 0.25);
        }

        .visitors-panel {
            padding: 0.9rem 1.25rem;
            min-height: 80px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: stretch;
            position: relative;
            overflow: hidden;
            margin-top: 0;
            background: var(--card-bg);
            border-color: var(--card-border);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.04);
        }

        .visitors-panel:hover {
            background: var(--card-bg-hover);
            box-shadow: 0 12px 40px 0 rgba(31, 38, 135, 0.08);
        }

        .visitors-core {
            width: 100%;
            display: grid;
            grid-template-columns: auto 1fr auto;
            align-items: center;
            column-gap: 0.95rem;
            min-height: auto;
        }

        .visitors-badge {
            width: 2.45rem;
            height: 2.45rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.72);
            color: #3b82f6;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            box-shadow: 0 8px 24px rgba(59, 130, 246, 0.1);
        }

        .visitors-value {
            margin: 0;
            font-size: 1.9rem;
            line-height: 1;
            letter-spacing: -0.04em;
            color: #1e293b;
            font-weight: 900;
            text-align: center;
            min-width: 7ch;
        }

        [id^="busuanzi_container_"] {
            display: inline-flex;
            justify-content: center;
            align-items: center;
        }

        [id^="busuanzi_value_"] {
            display: inline-block;
            min-width: 2ch;
        }

        .visitors-label {
            display: block;
            text-align: right;
            font-size: 0.56rem;
            line-height: 1.15;
            letter-spacing: 0.18em;
            color: #64748b;
            font-weight: 800;
            text-transform: uppercase;
            white-space: nowrap;
        }

        ::-webkit-scrollbar {
            width: 4px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(125, 211, 252, 0.8);
            border-radius: 10px;
        }

        @media (max-width: 1024px) {
            .home-grid {
                grid-template-columns: 1fr;
            }

            .left-column,
            .center-column,
            .right-column {
                grid-column: auto;
            }

            .center-bottom-grid {
                grid-template-columns: 1fr;
            }

            .latest-panel,
            .side-stack {
                grid-column: auto;
            }
        }

        @media (max-width: 768px) {
            .home-shell {
                padding: 1rem;
            }

            .home-grid,
            .left-column,
            .center-column,
            .right-column,
            .side-stack {
                gap: 1.5rem;
            }

            .hero-panel,
            .profile-panel,
            .nav-panel,
            .latest-panel {
                min-height: auto;
            }

            .hero-panel {
                padding: 2rem 1.5rem;
            }

            .hero-illustration {
                font-size: 9rem;
                right: -1rem;
                bottom: -1.5rem;
            }

            .photo-stack {
                left: 0.95rem;
                bottom: 0.5rem;
                transform: scale(0.88);
                transform-origin: bottom left;
            }
        }

        @media (prefers-reduced-motion: reduce) {
            body::after {
                transition: none;
            }

            body.is-page-leaving .page-transition-target {
                animation: none !important;
            }
        }
    </style>
</head>
<body>
    <%- body %>
    <% if (theme.visitor_counter && theme.visitor_counter.enable && (!theme.visitor_counter.provider || theme.visitor_counter.provider === 'busuanzi')) { %>
    <script async src="https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
    <% } %>

    <script>
        function updateClock() {
            const now = new Date();
            const hours = String(now.getHours()).padStart(2, '0');
            const minutes = String(now.getMinutes()).padStart(2, '0');

            const hoursEl = document.getElementById('time-hours');
            const minutesEl = document.getElementById('time-minutes');
            if (hoursEl) hoursEl.textContent = hours;
            if (minutesEl) minutesEl.textContent = minutes;

            const days = ['SUN', 'MON', 'TUE', 'WED', 'THU', 'FRI', 'SAT'];
            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, '0');
            const date = String(now.getDate()).padStart(2, '0');
            const day = days[now.getDay()];

            const dateEl = document.getElementById('date-full');
            if (dateEl) {
                dateEl.textContent = `${year} . ${month} . ${date} ${day}`;
            }

            const currentHour = now.getHours();
            let greeting = 'Evening';
            if (currentHour >= 5 && currentHour < 12) greeting = 'Morning';
            else if (currentHour >= 12 && currentHour < 18) greeting = 'Afternoon';

            const greetingEl = document.getElementById('greeting');
            if (greetingEl) greetingEl.textContent = greeting;
        }

        function renderCalendar(initialDate) {
            const titleEl = document.getElementById('calendar-title');
            const weekdaysEl = document.getElementById('calendar-weekdays');
            const daysEl = document.getElementById('calendar-days');
            const prevEl = document.getElementById('calendar-prev');
            const nextEl = document.getElementById('calendar-next');

            if (!titleEl || !weekdaysEl || !daysEl || !prevEl || !nextEl) return;

            const weekdayLabels = ['S', 'M', 'T', 'W', 'T', 'F', 'S'];
            weekdaysEl.innerHTML = weekdayLabels.map((label, index) => {
                const extra = index === 0 ? ' is-sun' : index === 6 ? ' is-sat' : '';
                return `<div class="calendar-weekday${extra}">${label}</div>`;
            }).join('');

            let current = new Date(initialDate.getFullYear(), initialDate.getMonth(), 1);

            const draw = () => {
                const today = new Date();
                const monthStart = new Date(current.getFullYear(), current.getMonth(), 1);
                const monthEnd = new Date(current.getFullYear(), current.getMonth() + 1, 0);
                const startWeekday = monthStart.getDay();
                const daysInMonth = monthEnd.getDate();
                const prevMonthEnd = new Date(current.getFullYear(), current.getMonth(), 0).getDate();
                const monthNames = [
                    'January', 'February', 'March', 'April', 'May', 'June',
                    'July', 'August', 'September', 'October', 'November', 'December'
                ];

                titleEl.textContent = `${monthNames[current.getMonth()]} ${current.getFullYear()}`;

                const cells = [];
                for (let i = startWeekday - 1; i >= 0; i -= 1) {
                    cells.push(`<div class="calendar-day is-muted">${prevMonthEnd - i}</div>`);
                }

                for (let day = 1; day <= daysInMonth; day += 1) {
                    const isToday =
                        today.getFullYear() === current.getFullYear() &&
                        today.getMonth() === current.getMonth() &&
                        today.getDate() === day;
                    cells.push(`<div class="calendar-day${isToday ? ' is-today' : ''}">${day}</div>`);
                }

                const remainder = cells.length % 7;
                const nextDays = remainder === 0 ? 0 : 7 - remainder;
                for (let day = 1; day <= nextDays; day += 1) {
                    cells.push(`<div class="calendar-day is-muted">${day}</div>`);
                }

                daysEl.innerHTML = cells.join('');
            };

            prevEl.addEventListener('click', () => {
                current = new Date(current.getFullYear(), current.getMonth() - 1, 1);
                draw();
            });

            nextEl.addEventListener('click', () => {
                current = new Date(current.getFullYear(), current.getMonth() + 1, 1);
                draw();
            });

            draw();
        }

        setInterval(updateClock, 1000);
        updateClock();
        renderCalendar(new Date());

        (() => {
            const root = document.documentElement;
            document.body.classList.remove('is-page-leaving');
            root.classList.remove('is-page-entering');

            const shell = document.querySelector('.home-shell, .blog-shell, .post-shell, .friends-shell, .photo-wall-shell, .guestbook-shell');
            if (!shell) return;

            const transitionTargetsByShell = {
                'home-shell': [
                    '.profile-panel',
                    '.nav-panel',
                    '.hero-panel',
                    '.latest-panel',
                    '.photo-panel',
                    '.activity-panel',
                    '.clock-panel',
                    '.calendar-panel',
                    '.visitors-panel'
                ],
                'blog-shell': [
                    '.blog-dock',
                    '.blog-status',
                    '.blog-hero',
                    '.blog-panel'
                ],
                'post-shell': [
                    '.post-dock',
                    '.post-status',
                    '.post-hero',
                    '.post-panel'
                ],
                'friends-shell': [
                    '.friends-dock',
                    '.friends-status',
                    '.friends-hero',
                    '.friends-panel'
                ],
                'photo-wall-shell': [
                    '.photo-wall-dock',
                    '.photo-wall-status',
                    '.photo-wall-board'
                ],
                'guestbook-shell': [
                    '.guestbook-dock',
                    '.guestbook-status',
                    '.guestbook-board'
                ]
            };

            const activeTargetSelector = Object.entries(transitionTargetsByShell)
                .find(([className]) => shell.classList.contains(className))?.[1]?.join(', ');

            if (!activeTargetSelector) return;

            const targets = Array.from(shell.querySelectorAll(activeTargetSelector))
                .filter((element) => !element.closest('.photo-wall-lightbox, .guestbook-lightbox, .guestbook-composer'));

            if (!targets.length) return;

            const shouldAnimatePath = (pathname) => {
                if (!pathname) return false;
                if (pathname.startsWith('/friends')) return true;
                if (pathname.startsWith('/archives')) return true;
                if (pathname.startsWith('/categories')) return true;
                if (pathname.startsWith('/tags')) return true;
                if (/^\/\d{4}\//.test(pathname)) return true;
                return false;
            };

            const prefetched = new Set();
            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
            const TRANSITION_STORAGE_KEY = 'sukiame-page-transition';
            const EXIT_ANIMATION_MS = 1080;
            const ENTER_ANIMATION_MS = 640;
            const MAX_STAGGER_MS = 56;
            const NAVIGATION_DELAY_MS = prefersReducedMotion.matches ? 0 : 1000;

            const afterNextPaint = (callback) => {
                window.requestAnimationFrame(() => {
                    window.requestAnimationFrame(callback);
                });
            };

            const prefetchPage = (url) => {
                if (!url || prefetched.has(url.href) || !shouldAnimatePath(url.pathname)) return;
                prefetched.add(url.href);

                const link = document.createElement('link');
                link.rel = 'prefetch';
                link.as = 'document';
                link.href = url.href;
                document.head.appendChild(link);

                fetch(url.href, { credentials: 'same-origin' }).catch(() => {});
            };

            const applyExitVectors = () => {
                const viewportCenterX = window.innerWidth / 2;
                const viewportCenterY = window.innerHeight / 2;
                const viewportRadius = Math.hypot(viewportCenterX, viewportCenterY);
                const fallbackAngleStep = (Math.PI * 2) / Math.max(targets.length, 1);

                targets.forEach((element, index) => {
                    const rect = element.getBoundingClientRect();
                    const centerX = rect.left + rect.width / 2;
                    const centerY = rect.top + rect.height / 2;
                    const deltaX = centerX - viewportCenterX;
                    const deltaY = centerY - viewportCenterY;
                    const magnitude = Math.hypot(deltaX, deltaY);
                    const angle = magnitude > 1
                        ? Math.atan2(deltaY, deltaX)
                        : (fallbackAngleStep * index) - (Math.PI / 2);
                    const radialX = Math.cos(angle);
                    const radialY = Math.sin(angle);
                    const travelDistance = viewportRadius + Math.max(rect.width, rect.height) * 0.62 + 150 + magnitude * 0.2;
                    const midDistance = travelDistance * 0.56;
                    const exitX = radialX * travelDistance;
                    const exitY = radialY * travelDistance;
                    const midX = radialX * midDistance;
                    const midY = radialY * midDistance;
                    const rotateSign = radialX === 0 ? (radialY >= 0 ? 1 : -1) : Math.sign(radialX);
                    const rotate = rotateSign * (4 + Math.min((magnitude / Math.max(viewportRadius, 1)) * 4.5, 4.5));
                    const midRotate = rotate * 0.46;
                    const enterDistance = Math.min(76, 42 + magnitude * 0.075);
                    const enterX = radialX * enterDistance;
                    const enterY = radialY * enterDistance;
                    const enterRotate = rotate * 0.34;
                    const normalizedDistance = magnitude / Math.max(viewportRadius, 1);
                    const delay = prefersReducedMotion.matches ? 0 : Math.pow(normalizedDistance, 1.12) * MAX_STAGGER_MS;
                    const scale = Math.max(0.91, 0.972 - normalizedDistance * 0.024);

                    element.classList.add('page-transition-target');
                    element.style.setProperty('--page-transition-index', index);
                    element.style.setProperty('--page-exit-duration', `${EXIT_ANIMATION_MS}ms`);
                    element.style.setProperty('--page-enter-duration', `${ENTER_ANIMATION_MS}ms`);
                    element.style.setProperty('--page-transition-delay', `${delay.toFixed(0)}ms`);
                    element.style.setProperty('--page-exit-mid-x', `${midX.toFixed(2)}px`);
                    element.style.setProperty('--page-exit-mid-y', `${midY.toFixed(2)}px`);
                    element.style.setProperty('--page-exit-x', `${exitX.toFixed(2)}px`);
                    element.style.setProperty('--page-exit-y', `${exitY.toFixed(2)}px`);
                    element.style.setProperty('--page-exit-mid-rotate', `${midRotate.toFixed(2)}deg`);
                    element.style.setProperty('--page-exit-rotate', `${rotate.toFixed(2)}deg`);
                    element.style.setProperty('--page-enter-x', `${enterX.toFixed(2)}px`);
                    element.style.setProperty('--page-enter-y', `${enterY.toFixed(2)}px`);
                    element.style.setProperty('--page-enter-rotate', `${enterRotate.toFixed(2)}deg`);
                    element.style.setProperty('--page-exit-scale', scale.toFixed(3));
                });
            };

            applyExitVectors();

            const transitionSnapshot = (() => {
                try {
                    const raw = window.sessionStorage.getItem(TRANSITION_STORAGE_KEY);
                    if (!raw) return null;
                    window.sessionStorage.removeItem(TRANSITION_STORAGE_KEY);
                    return JSON.parse(raw);
                } catch (error) {
                    return null;
                }
            })();

            if (
                transitionSnapshot &&
                !prefersReducedMotion.matches &&
                transitionSnapshot.href === window.location.href &&
                Date.now() - transitionSnapshot.at < 4000
            ) {
                afterNextPaint(() => {
                    root.classList.remove('is-page-enter-prep');
                    root.classList.add('is-page-entering');
                });

                window.setTimeout(() => {
                    root.classList.remove('is-page-entering');
                    root.classList.remove('is-page-enter-prep');
                }, ENTER_ANIMATION_MS + MAX_STAGGER_MS + 100);
            } else {
                root.classList.remove('is-page-enter-prep');
            }

            let navigating = false;
            document.addEventListener('click', (event) => {
                if (navigating) return;

                const link = event.target.closest('a');
                if (!link) return;
                if (link.target === '_blank' || link.hasAttribute('download')) return;
                if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;

                const href = link.getAttribute('href') || '';
                if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:') || href.endsWith('/atom.xml')) return;

                const nextUrl = new URL(link.href, window.location.href);
                if (nextUrl.origin !== window.location.origin) return;
                if (nextUrl.href === window.location.href) return;
                if (!shouldAnimatePath(nextUrl.pathname)) return;

                navigating = true;
                event.preventDefault();
                applyExitVectors();
                prefetchPage(nextUrl);
                try {
                    window.sessionStorage.setItem(TRANSITION_STORAGE_KEY, JSON.stringify({
                        href: nextUrl.href,
                        at: Date.now()
                    }));
                } catch (error) {}
                afterNextPaint(() => {
                    document.body.classList.add('is-page-leaving');
                });

                window.setTimeout(() => {
                    window.location.href = nextUrl.href;
                }, NAVIGATION_DELAY_MS);
            });

            document.addEventListener('pointerenter', (event) => {
                const link = event.target.closest('a');
                if (!link) return;
                const href = link.getAttribute('href') || '';
                if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;
                const nextUrl = new URL(link.href, window.location.href);
                if (nextUrl.origin !== window.location.origin) return;
                prefetchPage(nextUrl);
            }, true);

            window.setTimeout(() => {
                ['/archives/', '/friends/'].forEach((path) => {
                    prefetchPage(new URL(path, window.location.href));
                });
            }, 250);

            window.addEventListener('pageshow', () => {
                document.body.classList.remove('is-page-leaving');
                navigating = false;
            });

            window.addEventListener('resize', () => {
                if (!navigating) {
                    applyExitVectors();
                }
            });
        })();
    </script>
</body>
</html>

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%- page.title || config.title %></title>
    <link rel="icon" href="<%- /^(?:[a-z][a-z0-9+.-]*:)?\/\//i.test(theme.favicon || theme.avatar || '') ? (theme.favicon || theme.avatar) : url_for(theme.favicon || theme.avatar || '/images/avatar-cat.svg') %>">
    <link rel="preload" as="image" type="image/x-icon" href="<%- url_for('/cursors/cur118.cur') %>">
    <style>
        :root {
            --sukiame-cursor-default: url("data:image/png;base64,") 8 5, auto;
        }

        html,
        body,
        html *,
        body * {
            cursor: var(--sukiame-cursor-default) !important;
        }
    </style>
    <script>
        (() => {
            if (window.__sukiamePageScope) return;

            const scope = {
                active: false,
                disposers: [],
                originals: null
            };

            const addDisposer = (callback) => {
                if (typeof callback === 'function') scope.disposers.push(callback);
            };

            const callListener = (listener, target, event) => {
                if (typeof listener === 'function') {
                    listener.call(target, event);
                } else if (listener && typeof listener.handleEvent === 'function') {
                    listener.handleEvent(event);
                }
            };

            const end = () => {
                if (!scope.active || !scope.originals) return;

                EventTarget.prototype.addEventListener = scope.originals.addEventListener;
                window.setInterval = scope.originals.setInterval;
                scope.active = false;
                scope.originals = null;
            };

            const begin = () => {
                if (scope.active) return;

                const originals = {
                    addEventListener: EventTarget.prototype.addEventListener,
                    removeEventListener: EventTarget.prototype.removeEventListener,
                    setInterval: window.setInterval,
                    clearInterval: window.clearInterval
                };

                scope.originals = originals;
                scope.active = true;

                EventTarget.prototype.addEventListener = function(type, listener, options) {
                    originals.addEventListener.call(this, type, listener, options);

                    if (listener) {
                        const target = this;
                        addDisposer(() => {
                            originals.removeEventListener.call(target, type, listener, options);
                        });
                    }

                    if (
                        this === document &&
                        type === 'DOMContentLoaded' &&
                        document.readyState !== 'loading' &&
                        listener
                    ) {
                        window.queueMicrotask(() => {
                            callListener(listener, document, new Event('DOMContentLoaded'));
                        });
                    }
                };

                window.setInterval = function(handler, timeout, ...args) {
                    const id = originals.setInterval.call(window, handler, timeout, ...args);
                    addDisposer(() => originals.clearInterval.call(window, id));
                    return id;
                };
            };

            const clear = () => {
                try {
                    window.dispatchEvent(new CustomEvent('sukiame:page-unload'));
                } catch (error) {}

                end();

                while (scope.disposers.length) {
                    const dispose = scope.disposers.pop();
                    try {
                        dispose();
                    } catch (error) {}
                }

                document.querySelectorAll('.code-block-modal').forEach((element) => {
                    element.remove();
                });

                if (document.body) {
                    document.body.classList.remove(
                        'photo-wall-lightbox-open',
                        'guestbook-lightbox-open',
                        'guestbook-composer-open'
                    );
                }
            };

            try {
                window.sessionStorage.removeItem('sukiame-page-transition');
            } catch (error) {}

            window.__sukiameUsePjax = true;
            window.__sukiamePageScope = { begin, end, clear };
            window.__sukiameBeginPageScope = begin;
            window.__sukiameEndPageScope = end;
            window.__sukiameClearPageScope = clear;
        })();
    </script>
    <link rel="alternate" type="application/atom+xml" title="<%- config.title || 'RSS Feed' %>" href="<%- url_for('/atom.xml') %>">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="<%- url_for('/vendor/katex/katex.min.css') %>">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=ZCOOL+KuaiLe&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Nunito', 'sans-serif'],
                        cute: ['ZCOOL KuaiLe', 'cursive'],
                    },
                    colors: {
                        'rain-light': '#e0f2fe',
                        'rain-blue': '#7dd3fc',
                        'rain-dark': '#0369a1',
                    }
                }
            }
        }
    </script>
    <style>
        :root {
            --card-bg: rgba(255, 255, 255, 0.4);
            --card-bg-hover: rgba(255, 255, 255, 0.55);
            --card-border: rgba(255, 255, 255, 0.8);
            --text-main: #334155;
            --text-soft: #64748b;
            --text-muted: #94a3b8;
            --rain-blue: #7dd3fc;
            --rain-dark: #0369a1;
        }

        * {
            box-sizing: border-box;
        }

        html {
            cursor: var(--sukiame-cursor-default);
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(-45deg, #e0f2fe, #bae6fd, #f3e8ff, #e0e7ff);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
            color: var(--text-main);
            cursor: var(--sukiame-cursor-default);
            font-family: 'Nunito', sans-serif;
        }

        body::after {
            content: "";
            position: fixed;
            inset: 0;
            background:
                radial-gradient(circle at 18% 22%, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0) 28%),
                radial-gradient(circle at 82% 18%, rgba(186, 230, 253, 0.24), rgba(186, 230, 253, 0) 26%),
                linear-gradient(135deg, rgba(224, 242, 254, 0.2), rgba(243, 232, 255, 0.18));
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.64s cubic-bezier(0.2, 0.76, 0.2, 1);
            z-index: 999;
        }

        body.is-page-leaving::after {
            opacity: 1;
        }

        body.is-page-leaving {
            pointer-events: none;
        }

        html.is-page-navigating,
        html.is-page-navigating body,
        html.is-page-navigating body *,
        html.is-page-enter-prep,
        html.is-page-enter-prep body,
        html.is-page-enter-prep body *,
        html.is-page-entering,
        html.is-page-entering body,
        html.is-page-entering body * {
            cursor: var(--sukiame-cursor-default) !important;
        }

        .sakura-click-petal {
            position: fixed;
            pointer-events: none;
            width: 18px;
            height: 12px;
            background: linear-gradient(135deg, #ffd7e6 0%, #ffc2d7 45%, #ff9fbe 100%);
            border-radius: 70% 0 70% 0;
            box-shadow: 0 0 8px rgba(255, 192, 203, 0.35);
            transform-origin: center;
            z-index: 10000;
            will-change: transform, opacity;
            animation: sakuraClickFly 1400ms cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
        }

        .sakura-click-petal::after {
            content: "";
            position: absolute;
            width: 55%;
            height: 20%;
            top: 18%;
            left: 18%;
            background: rgba(255, 255, 255, 0.5);
            border-radius: 999px;
            filter: blur(1px);
            transform: rotate(-20deg);
        }

        @keyframes sakuraClickFly {
            0% {
                opacity: var(--petal-opacity, 1);
                transform: translate3d(0, 0, 0) rotate(var(--petal-start-rotate, 0deg)) scale(var(--petal-start-scale, 1));
            }

            100% {
                opacity: 0;
                transform: translate3d(var(--petal-x), var(--petal-y), 0) rotate(var(--petal-rotate)) scale(var(--petal-end-scale, 0.35));
            }
        }

        .page-transition-target {
            will-change: transform, opacity;
            transform-origin: center center;
            backface-visibility: hidden;
            transform-style: preserve-3d;
            contain: paint;
            isolation: isolate;
            --page-exit-duration: 1060ms;
            --page-enter-duration: 620ms;
            --page-transition-delay: 0ms;
            --page-exit-scale: 0.88;
        }

        body.is-page-leaving .page-transition-target {
            animation: pageTransitionOut var(--page-exit-duration) cubic-bezier(0.2, 0.74, 0.18, 1) both;
            animation-delay: var(--page-transition-delay);
            pointer-events: none;
        }

        html.is-page-entering .page-transition-target {
            animation: pageTransitionIn var(--page-enter-duration) cubic-bezier(0.14, 0.82, 0.2, 1) both;
            animation-delay: var(--page-transition-delay);
            pointer-events: none;
        }

        html.is-page-enter-prep .page-transition-target {
            opacity: 0;
            transform: translate3d(var(--page-enter-x, 0px), var(--page-enter-y, 0px), 0) scale(0.972) rotate(var(--page-enter-rotate, 0deg));
            pointer-events: none;
        }

        html.is-page-enter-prep .profile-panel,
        html.is-page-enter-prep .nav-panel,
        html.is-page-enter-prep .hero-panel,
        html.is-page-enter-prep .latest-panel,
        html.is-page-enter-prep .photo-panel,
        html.is-page-enter-prep .activity-panel,
        html.is-page-enter-prep .clock-panel,
        html.is-page-enter-prep .calendar-panel,
        html.is-page-enter-prep .visitors-panel,
        html.is-page-enter-prep .blog-dock,
        html.is-page-enter-prep .blog-status,
        html.is-page-enter-prep .blog-hero,
        html.is-page-enter-prep .blog-panel,
        html.is-page-enter-prep .post-dock,
        html.is-page-enter-prep .post-status,
        html.is-page-enter-prep .post-hero,
        html.is-page-enter-prep .post-panel,
        html.is-page-enter-prep .friends-dock,
        html.is-page-enter-prep .friends-status,
        html.is-page-enter-prep .friends-hero,
        html.is-page-enter-prep .friends-panel,
        html.is-page-enter-prep .photo-wall-dock,
        html.is-page-enter-prep .photo-wall-status,
        html.is-page-enter-prep .photo-wall-board,
        html.is-page-enter-prep .guestbook-dock,
        html.is-page-enter-prep .guestbook-status,
        html.is-page-enter-prep .guestbook-board {
            opacity: 0;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        @keyframes pageTransitionOut {
            0% {
                opacity: 1;
                transform: translate3d(0, 0, 0) scale(1) rotate(0deg);
            }

            32% {
                opacity: 0.997;
                transform: translate3d(calc(var(--page-exit-mid-x, 0px) * 0.4), calc(var(--page-exit-mid-y, 0px) * 0.4), 0) scale(0.995) rotate(calc(var(--page-exit-mid-rotate, 0deg) * 0.48));
            }

            70% {
                opacity: 0.952;
                transform: translate3d(var(--page-exit-mid-x, 0px), var(--page-exit-mid-y, 0px), 0) scale(0.986) rotate(var(--page-exit-mid-rotate, 0deg));
            }

            100% {
                opacity: 0;
                transform: translate3d(var(--page-exit-x, 0px), var(--page-exit-y, 0px), 0) scale(var(--page-exit-scale, 0.88)) rotate(var(--page-exit-rotate, 0deg));
            }
        }

        @keyframes pageTransitionIn {
            0% {
                opacity: 0;
                transform: translate3d(var(--page-enter-x, 0px), var(--page-enter-y, 0px), 0) scale(0.972) rotate(var(--page-enter-rotate, 0deg));
            }

            68% {
                opacity: 0.99;
                transform: translate3d(calc(var(--page-enter-x, 0px) * 0.14), calc(var(--page-enter-y, 0px) * 0.14), 0) scale(0.997) rotate(calc(var(--page-enter-rotate, 0deg) * 0.14));
            }

            100% {
                opacity: 1;
                transform: translate3d(0, 0, 0) scale(1) rotate(0deg);
            }
        }

        a {
            color: inherit;
            cursor: var(--sukiame-cursor-default);
            text-decoration: none;
        }

        [role="button"],
        summary,
        label,
        select,
        input[type="button"],
        input[type="submit"],
        input[type="reset"] {
            cursor: var(--sukiame-cursor-default);
        }

        button {
            border: 0;
            background: transparent;
            cursor: var(--sukiame-cursor-default);
            font: inherit;
        }

        .home-shell {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
            position: relative;
            overflow-x: hidden;
        }

        .home-grid {
            width: min(1350px, 100%);
            display: grid;
            grid-template-columns: repeat(12, minmax(0, 1fr));
            gap: 2rem;
            align-items: start;
            margin: auto 0;
            position: relative;
            z-index: 1;
        }

        .left-column,
        .center-column,
        .right-column {
            display: flex;
            flex-direction: column;
            gap: 1.75rem;
        }

        .right-column {
            gap: 1rem;
            align-self: start;
            justify-content: flex-start;
            height: calc(310px + 1.75rem + 330px);
        }

        .left-column { grid-column: span 3 / span 3; }
        .center-column { grid-column: span 6 / span 6; }
        .right-column { grid-column: span 3 / span 3; }

        .glass-card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--card-border);
            border-right: 1px solid rgba(255, 255, 255, 0.4);
            border-bottom: 1px solid rgba(255, 255, 255, 0.4);
            border-radius: 1.5rem;
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.04);
            transition: all 0.3s ease;
        }

        .glass-card:hover {
            background: var(--card-bg-hover);
            box-shadow: 0 12px 40px 0 rgba(31, 38, 135, 0.08);
            transform: translateY(-2px);
        }

        .profile-panel {
            min-height: 310px;
            padding: 2rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .profile-avatar-box {
            position: relative;
            width: 6rem;
            height: 6rem;
            margin-bottom: 1.25rem;
            cursor: var(--sukiame-cursor-default);
        }

        .profile-avatar {
            width: 100%;
            height: 100%;
            border-radius: 999px;
            object-fit: cover;
            border: 3px solid #fff;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.12);
        }

        .profile-status {
            position: absolute;
            right: 0;
            bottom: 0;
            width: 1.25rem;
            height: 1.25rem;
            border-radius: 999px;
            background: #4ade80;
            border: 2px solid #fff;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.08);
        }

        .profile-title {
            margin: 0;
            font-size: 2rem;
            line-height: 1;
            color: #1e293b;
            letter-spacing: 0.03em;
        }

        .profile-subtitle {
            margin: 0.75rem 0 0;
            font-size: 13px;
            color: #64748b;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.375rem;
        }

        .profile-actions {
            width: 100%;
            display: flex;
            justify-content: center;
            gap: 1rem;
            margin-top: 1.25rem;
        }

        .profile-actions a {
            width: 2.25rem;
            height: 2.25rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.6);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #64748b;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.06);
            transition: all 0.25s ease;
        }

        .profile-actions a:hover {
            background: #fff;
            transform: translateY(-4px);
        }

        .nav-panel {
            position: relative;
            overflow: hidden;
            min-height: 330px;
            padding: 1.5rem 1.25rem;
            display: flex;
            flex-direction: column;
        }

        .nav-panel-icon {
            position: absolute;
            top: -1.5rem;
            right: -1.5rem;
            font-size: 5.5rem;
            color: rgba(255, 255, 255, 0.3);
            pointer-events: none;
        }

        .section-kicker {
            margin: 0 0 1.25rem;
            padding-left: 0.5rem;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #94a3b8;
            position: relative;
            z-index: 1;
        }

        .nav-links {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .nav-link {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.875rem;
            border-radius: 0.875rem;
            color: #64748b;
            transition: all 0.25s ease;
        }

        .nav-link:hover {
            background: rgba(255, 255, 255, 0.6);
            color: #1e293b;
        }

        .active-nav {
            background: #fff;
            border-left: 4px solid #0369a1;
            border-radius: 6px 14px 14px 6px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
            color: #0369a1;
        }

        .nav-link-label {
            display: flex;
            align-items: center;
            gap: 1rem;
            font-size: 15px;
            font-weight: 700;
        }

        .nav-link-label i {
            width: 1.5rem;
            text-align: center;
            font-size: 1.125rem;
        }

        .nav-link-arrow {
            color: #94a3b8;
            font-size: 0.875rem;
            transition: color 0.25s ease;
        }

        .nav-link:hover .nav-link-arrow {
            color: #334155;
        }

        .nav-link-arrow-fade {
            opacity: 0;
            transition: opacity 0.25s ease;
        }

        .nav-link:hover .nav-link-arrow-fade {
            opacity: 1;
        }

        .hero-panel {
            min-height: 310px;
            padding: 2.5rem;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .hero-illustration {
            position: absolute;
            right: -1rem;
            bottom: -1rem;
            font-size: 13rem;
            color: rgba(255, 255, 255, 0.4);
            pointer-events: none;
            transition: transform 0.7s ease;
        }

        .hero-panel:hover .hero-illustration {
            transform: scale(1.1);
        }

        .hero-content {
            position: relative;
            z-index: 1;
        }

        .hero-top-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 0.5rem;
        }

        .hero-greeting {
            margin: 0;
            font-size: 1.25rem;
            color: #64748b;
            font-weight: 700;
        }

        .hero-title {
            margin: 0 0 1rem;
            font-size: clamp(2.5rem, 6vw, 3.5rem);
            line-height: 1.1;
            font-weight: 900;
            color: #1e293b;
        }

        .hero-name {
            background: linear-gradient(to right, #0369a1, #3b82f6, #8b5cf6);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: 0.05em;
            padding-bottom: 0.125rem;
        }

        .hero-copy {
            margin: 0;
            max-width: 34rem;
            padding-left: 1rem;
            border-left: 4px solid #7dd3fc;
            color: #64748b;
            font-size: 1rem;
            line-height: 1.75;
            font-weight: 600;
        }

        .hero-copy-text {
            margin: 0;
        }

        .hero-copy-source {
            display: block;
            margin-top: 0.15rem;
            text-align: right;
            font-size: 0.92rem;
            color: #7b8798;
        }

        .hero-action-row {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            flex: none;
        }

        .heart-pill-btn {
            min-width: 8.8rem;
            height: 3rem;
            padding: 0 1.1rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.8rem;
            border-radius: 999px;
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.78);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.2s, border-color 0.2s;
            user-select: none;
            -webkit-user-select: none;
        }

        .heart-pill-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 12px -2px rgba(0, 0, 0, 0.15), 0 3px 6px -2px rgba(0, 0, 0, 0.1);
        }

        .heart-pill-btn:active {
            transform: translateY(1px) scale(0.96);
        }

        .heart-pill-btn.is-liked {
            border-color: rgba(248, 113, 113, 0.26);
        }

        .heart-count-divider {
            width: 1px;
            height: 1.25rem;
            background: rgba(248, 113, 113, 0.18);
            flex: none;
        }

        .heart-icon {
            flex: none;
            color: #f87171;
            transition: color 0.2s ease;
        }

        .heart-pill-btn.is-liked .heart-icon {
            color: #ef4444;
        }

        .like-count {
            font-family: 'Nunito', sans-serif;
            font-size: 1.05rem;
            line-height: 1;
            font-weight: 900;
            color: #475569;
            letter-spacing: 0.01em;
        }

        .heart-icon.animating,
        .like-count.animating {
            animation: heartPop 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }

        @keyframes heartPop {
            0% { transform: scale(1); }
            50% { transform: scale(1.4); }
            100% { transform: scale(1); }
        }

        .center-bottom-grid {
            min-height: 330px;
            display: grid;
            grid-template-columns: repeat(5, minmax(0, 1fr));
            gap: 1.75rem;
        }

        .latest-panel {
            grid-column: span 3 / span 3;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            min-height: 330px;
        }

        .panel-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.25rem;
        }

        .panel-title {
            margin: 0;
            font-size: 15px;
            font-weight: 800;
            color: #334155;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .panel-title-bar {
            width: 0.25rem;
            height: 1rem;
            border-radius: 999px;
            background: #7dd3fc;
        }

        .panel-link {
            font-size: 10px;
            color: #94a3b8;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .post-list {
            display: flex;
            flex-direction: column;
            gap: 0.625rem;
        }

        .post-row {
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            padding: 0.75rem;
            border-radius: 0.75rem;
            transition: background 0.25s ease;
        }

        .post-row:hover {
            background: rgba(255, 255, 255, 0.6);
        }

        .post-icon {
            width: 3rem;
            height: 3rem;
            border-radius: 0.75rem;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }

        .post-cover-thumb {
            width: 3rem;
            height: 3rem;
            border-radius: 0.75rem;
            overflow: hidden;
            flex-shrink: 0;
            box-shadow: 0 8px 20px rgba(148, 163, 184, 0.16);
            background: linear-gradient(135deg, #bae6fd, #d9f99d);
        }

        .post-cover-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.28s ease;
        }

        .post-row:hover .post-cover-thumb img {
            transform: scale(1.06);
        }

        .post-row:hover .post-icon {
            color: #fff;
        }

        .post-icon-blue {
            background: rgba(239, 246, 255, 0.8);
            color: #3b82f6;
        }

        .post-row:hover .post-icon-blue {
            background: #3b82f6;
        }

        .post-icon-green {
            background: rgba(240, 253, 244, 0.8);
            color: #22c55e;
        }

        .post-row:hover .post-icon-green {
            background: #22c55e;
        }

        .post-icon-purple {
            background: rgba(245, 243, 255, 0.8);
            color: #a855f7;
        }

        .post-row:hover .post-icon-purple {
            background: #a855f7;
        }

        .post-text {
            min-width: 0;
            flex: 1;
            padding-top: 0.125rem;
        }

        .post-title {
            margin: 0 0 0.25rem;
            font-size: 0.875rem;
            font-weight: 700;
            color: #334155;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .post-excerpt {
            margin: 0;
            font-size: 11px;
            color: #64748b;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .post-date {
            flex-shrink: 0;
            font-size: 10px;
            font-weight: 700;
            color: #94a3b8;
            padding-top: 0.375rem;
        }

        .side-stack {
            grid-column: span 2 / span 2;
            min-height: 330px;
            display: flex;
            flex-direction: column;
            gap: 1.75rem;
        }

        .photo-panel,
        .activity-panel {
            min-height: 140px;
            padding: 1.25rem;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .photo-panel {
            min-height: 152px;
            padding: 1.25rem 1.15rem 1.05rem;
            align-items: flex-start;
            justify-content: flex-start;
            text-align: left;
            background: var(--card-bg);
            border-color: var(--card-border);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.04);
        }

        .photo-panel::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0) 58%);
            pointer-events: none;
        }

        .photo-panel:hover {
            background: var(--card-bg-hover);
            box-shadow: 0 12px 40px 0 rgba(31, 38, 135, 0.08);
        }

        .photo-glow,
        .activity-glow {
            position: absolute;
            right: -20px;
            bottom: -20px;
            width: 6rem;
            height: 6rem;
            border-radius: 999px;
            filter: blur(32px);
            opacity: 0.4;
            transition: opacity 0.25s ease, transform 0.35s ease;
            pointer-events: none;
        }

        .photo-glow {
            top: -2.4rem;
            right: -0.8rem;
            bottom: auto;
            width: 8rem;
            height: 8rem;
            background: radial-gradient(circle, rgba(125, 211, 252, 0.3) 0%, rgba(224, 242, 254, 0.22) 42%, rgba(255, 255, 255, 0) 72%);
            filter: blur(18px);
            opacity: 0.72;
        }

        .activity-glow {
            background: linear-gradient(to bottom right, #5eead4, #d1fae5);
        }

        .photo-panel:hover .photo-glow,
        .activity-panel:hover .activity-glow {
            opacity: 0.8;
        }

        .photo-panel:hover .photo-glow {
            opacity: 1;
            transform: scale(1.06);
        }

        .photo-copy,
        .activity-head {
            position: relative;
            z-index: 1;
        }

        .photo-copy h3,
        .activity-head h3 {
            margin: 0;
            font-size: 1rem;
            font-weight: 800;
            color: #1e293b;
        }

        .photo-copy p,
        .activity-head p {
            margin: 0.25rem 0 0;
            font-size: 11px;
            color: #64748b;
            font-weight: 600;
        }

        .photo-stack {
            position: absolute;
            left: 1.15rem;
            bottom: 0.6rem;
            width: 8.9rem;
            height: 5.95rem;
            z-index: 1;
            pointer-events: none;
            transform: none;
            transform-origin: bottom left;
        }

        .photo-shot {
            position: absolute;
            background: #fff;
            padding: 0.18rem 0.18rem 0.46rem;
            border-radius: 0.8rem;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.75);
            box-shadow: 0 12px 24px rgba(79, 98, 140, 0.22);
            z-index: 0;
            transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s ease;
        }

        .photo-shot img {
            position: relative;
            z-index: 1;
            width: 100%;
            height: calc(100% - 0.08rem);
            object-fit: cover;
            display: block;
            border-radius: 0.5rem;
        }

        .photo-shot-label {
            position: absolute;
            left: 0.28rem;
            right: 0.28rem;
            bottom: 0.12rem;
            z-index: 2;
            text-align: center;
            font-size: 0.56rem;
            line-height: 1;
            color: #475569;
            font-weight: 800;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .photo-shot::before,
        .photo-shot::after {
            content: "";
            position: absolute;
            inset: 0.18rem 0.18rem 0.46rem;
            border-radius: 0.5rem;
        }

        .photo-shot::after {
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0) 48%);
        }

        .photo-shot.has-image::before {
            display: none;
        }

        .photo-shot-one::before {
            background:
                radial-gradient(circle at 62% 26%, rgba(255, 230, 182, 0.95), rgba(255, 230, 182, 0) 16%),
                linear-gradient(180deg, rgba(18, 32, 70, 0.12) 0%, rgba(18, 32, 70, 0) 18%),
                linear-gradient(180deg, #1e2a4c 0%, #314a79 48%, #ea8b72 100%);
        }

        .photo-shot-two::before {
            background:
                radial-gradient(circle at 50% 24%, rgba(221, 242, 248, 0.9), rgba(221, 242, 248, 0) 22%),
                linear-gradient(180deg, rgba(255, 255, 255, 0.14) 0%, rgba(255, 255, 255, 0) 20%),
                linear-gradient(180deg, #2f4d5d 0%, #416f76 54%, #98b8b0 100%);
        }

        .photo-shot-one {
            left: 0.05rem;
            bottom: 0.3rem;
            width: 3.85rem;
            height: 4.8rem;
            transform: rotate(-11deg);
            z-index: 2;
        }

        .photo-shot-two {
            left: 4.2rem;
            bottom: 0;
            width: 3.85rem;
            height: 4.8rem;
            transform: rotate(12deg);
            z-index: 1;
        }

        .photo-panel:hover .photo-shot-one {
            transform: rotate(-15deg) translateY(-3px) scale(1.03);
            box-shadow: 0 14px 24px rgba(79, 98, 140, 0.24);

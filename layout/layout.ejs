        }

        .photo-badge {
            width: 2.75rem;
            height: 2.75rem;
            border-radius: 1rem;
            background: rgba(255, 255, 255, 0.7);
            color: #3b82f6;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 22px rgba(59, 130, 246, 0.1);
            position: absolute;
            top: 1.25rem;
            right: 1rem;
            z-index: 2;
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

        .photo-panel:hover .photo-badge {
            transform: translateY(-2px) scale(1.04);
            box-shadow: 0 12px 24px rgba(59, 130, 246, 0.14);
        }

        .photo-badge i {
            font-size: 1rem;
        }

        .photo-copy {
            width: 100%;
            max-width: none;
            padding-right: 4.6rem;
        }

        .photo-copy h3 {
            font-size: 1.08rem;
            line-height: 1.15;
            font-weight: 800;
            letter-spacing: -0.01em;
            color: #1e293b;
        }

        .photo-copy p {
            margin-top: 0.3rem;
            font-size: 0.72rem;
            color: #64748b;
            font-weight: 600;
        }

        .activity-panel {
            align-items: stretch;
            justify-content: flex-start;
        }

        .activity-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 1rem;
        }

        .activity-head p {
            margin-top: 0.2rem;
        }

        .activity-icon {
            color: #f87171;
            font-size: 1.15rem;
            margin-top: 0.15rem;
        }

        .activity-grid {
            position: relative;
            z-index: 1;
            display: grid;
            grid-auto-flow: column;
            grid-template-rows: repeat(2, 0.72rem);
            grid-auto-columns: 0.72rem;
            gap: 0.55rem 0.42rem;
            margin-top: auto;
            justify-content: start;
        }

        .activity-cell {
            width: 0.72rem;
            height: 0.72rem;
            border-radius: 0.16rem;
            background: rgba(241, 245, 249, 0.78);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.45);
        }

        .activity-cell.level-0 { background: rgba(235, 237, 240, 0.95); }
        .activity-cell.level-1 { background: #9be9a8; }
        .activity-cell.level-2 { background: #40c463; }
        .activity-cell.level-3 { background: #30a14e; }

        .clock-panel,
        .calendar-panel {
            flex-shrink: 0;
        }

        .clock-panel {
            min-height: 118px;
            padding: 1.25rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .clock-display {
            display: flex;
            align-items: baseline;
            justify-content: center;
            gap: 0.5rem;
        }

        .clock-display span {
            font-size: 3rem;
            font-weight: 900;
            color: #334155;
            letter-spacing: -0.04em;
        }

        .clock-separator {
            font-size: 1.875rem;
            color: #93c5fd;
            position: relative;
            top: -0.25rem;
            animation: pulse 2s ease-in-out infinite;
        }

        .clock-meta {
            margin-top: 0.75rem;
            font-size: 10px;
            font-weight: 800;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #94a3b8;
        }

        .calendar-panel {
            flex: 1;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            min-height: 398px;
        }

        .calendar-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.25rem;
        }

        .calendar-month {
            font-size: 0.875rem;
            font-weight: 900;
            color: #334155;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }

        .calendar-arrows {
            display: flex;
            gap: 0.375rem;
        }

        .calendar-arrow {
            width: 1.5rem;
            height: 1.5rem;
            border-radius: 0.375rem;
            background: rgba(255, 255, 255, 0.6);
            color: #94a3b8;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.06);
            transition: all 0.25s ease;
        }

        .calendar-arrow:hover {
            color: #334155;
            background: #fff;
        }

        .calendar-weekdays,
        .calendar-days {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            text-align: center;
            font-size: 11px;
        }

        .calendar-weekdays {
            gap: 0.25rem;
            margin-bottom: 0.35rem;
        }

        .calendar-weekday {
            font-weight: 700;
            color: #94a3b8;
            margin-bottom: 0.25rem;
        }

        .calendar-weekday.is-sun { color: #f472b6; font-weight: 900; }
        .calendar-weekday.is-sat { color: #60a5fa; font-weight: 900; }

        .calendar-days {
            gap: 0.34rem 0.18rem;
            min-height: 298px;
        }

        .calendar-day {
            aspect-ratio: 1 / 1;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
            color: #475569;
            border-radius: 0.625rem;
            transition: color 0.25s ease, box-shadow 0.25s ease;
        }

        .calendar-day:hover {
            color: #0369a1;
        }

        .calendar-day.is-muted {
            color: #cbd5e1;
            font-weight: 500;
        }

        .calendar-day.is-today {
            background: linear-gradient(to bottom right, #60a5fa, #6366f1);
            color: #fff;
            font-weight: 900;
            box-shadow: 0 8px 18px rgba(99, 102, 241, 0.25);
        }

        .visitors-panel {
            padding: 0.9rem 1.25rem;
            min-height: 80px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: stretch;
            position: relative;
            overflow: hidden;
            margin-top: 0;
            background: var(--card-bg);
            border-color: var(--card-border);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.04);
        }

        .visitors-panel:hover {
            background: var(--card-bg-hover);
            box-shadow: 0 12px 40px 0 rgba(31, 38, 135, 0.08);
        }

        .visitors-core {
            width: 100%;
            display: grid;
            grid-template-columns: auto 1fr auto;
            align-items: center;
            column-gap: 0.95rem;
            min-height: auto;
        }

        .visitors-badge {
            width: 2.45rem;
            height: 2.45rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.72);
            color: #3b82f6;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            box-shadow: 0 8px 24px rgba(59, 130, 246, 0.1);
        }

        .visitors-value {
            margin: 0;
            font-size: 1.9rem;
            line-height: 1;
            letter-spacing: -0.04em;
            color: #1e293b;
            font-weight: 900;
            text-align: center;
            min-width: 7ch;
        }

        [id^="busuanzi_container_"] {
            display: inline-flex;
            justify-content: center;
            align-items: center;
        }

        [id^="busuanzi_value_"] {
            display: inline-block;
            min-width: 2ch;
        }

        .visitors-label {
            display: block;
            text-align: right;
            font-size: 0.56rem;
            line-height: 1.15;
            letter-spacing: 0.18em;
            color: #64748b;
            font-weight: 800;
            text-transform: uppercase;
            white-space: nowrap;
        }

        ::-webkit-scrollbar {
            width: 4px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(125, 211, 252, 0.8);
            border-radius: 10px;
        }

        @media (max-width: 1024px) {
            .home-grid {
                grid-template-columns: 1fr;
            }

            .left-column,
            .center-column,
            .right-column {
                grid-column: auto;
            }

            .center-bottom-grid {
                grid-template-columns: 1fr;
            }

            .latest-panel,
            .side-stack {
                grid-column: auto;
            }
        }

        @media (max-width: 768px) {
            .home-shell {
                padding: 1rem;
            }

            .home-grid,
            .left-column,
            .center-column,
            .right-column,
            .side-stack {
                gap: 1.5rem;
            }

            .hero-panel,
            .profile-panel,
            .nav-panel,
            .latest-panel {
                min-height: auto;
            }

            .hero-panel {
                padding: 2rem 1.5rem;
            }

            .hero-top-row {
                gap: 0.85rem;
            }

            .hero-action-row {
                margin-top: 0;
            }

            .hero-illustration {
                font-size: 9rem;
                right: -1rem;
                bottom: -1.5rem;
            }

            .photo-stack {
                left: 0.95rem;
                bottom: 0.5rem;
                transform: scale(0.88);
                transform-origin: bottom left;
            }
        }

        @media (max-width: 640px) {
            .hero-top-row {
                flex-direction: column;
                align-items: flex-start;
            }

            .hero-action-row {
                width: 100%;
                justify-content: flex-start;
            }

            .heart-pill-btn {
                min-width: 7.6rem;
                height: 2.8rem;
                padding: 0 0.95rem;
                gap: 0.65rem;
            }

            .like-count {
                font-size: 0.98rem;
            }
        }

        @media (prefers-reduced-motion: reduce) {
            body::after {
                transition: none;
            }

            body.is-page-leaving .page-transition-target {
                animation: none !important;
            }
        }
    </style>
</head>
<body>
    <script>window.__sukiameBeginPageScope && window.__sukiameBeginPageScope();</script>
    <div id="sukiame-page-root" data-pjax-root>
        <%- body %>
    </div>
    <script>window.__sukiameEndPageScope && window.__sukiameEndPageScope();</script>
    <% if (theme.visitor_counter && theme.visitor_counter.enable && (!theme.visitor_counter.provider || theme.visitor_counter.provider === 'busuanzi')) { %>
    <script async src="https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
    <% } %>

    <script>
        (() => {
            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
            const PETAL_COUNT = 14;
            const PETAL_LIFE_MS = 1400;
            const MAX_PETALS = 160;
            const activePetals = [];

            const prunePetals = () => {
                while (activePetals.length > MAX_PETALS) {
                    const petal = activePetals.shift();
                    if (petal) petal.remove();
                }
            };

            document.addEventListener('click', (event) => {
                if (prefersReducedMotion.matches) return;

                for (let i = 0; i < PETAL_COUNT; i += 1) {
                    const petal = document.createElement('div');
                    const startScale = Math.random() * 0.8 + 0.7;

                    petal.className = 'sakura-click-petal';
                    petal.style.left = `${event.clientX}px`;
                    petal.style.top = `${event.clientY}px`;
                    petal.style.setProperty('--petal-x', `${(Math.random() - 0.5) * 260}px`);
                    petal.style.setProperty('--petal-y', `${(Math.random() - 0.5) * 220 - 40}px`);
                    petal.style.setProperty('--petal-rotate', `${Math.random() * 720 - 360}deg`);
                    petal.style.setProperty('--petal-start-rotate', `${Math.random() * 360}deg`);
                    petal.style.setProperty('--petal-start-scale', startScale.toFixed(2));
                    petal.style.setProperty('--petal-end-scale', (startScale * 0.35).toFixed(2));
                    petal.style.setProperty('--petal-opacity', (Math.random() * 0.4 + 0.6).toFixed(2));

                    document.body.appendChild(petal);
                    activePetals.push(petal);

                    window.setTimeout(() => {
                        petal.remove();
                        const index = activePetals.indexOf(petal);
                        if (index !== -1) activePetals.splice(index, 1);
                    }, PETAL_LIFE_MS);
                }

                prunePetals();
            });
        })();

        function updateClock() {
            const now = new Date();
            const hours = String(now.getHours()).padStart(2, '0');
            const minutes = String(now.getMinutes()).padStart(2, '0');

            const hoursEl = document.getElementById('time-hours');
            const minutesEl = document.getElementById('time-minutes');
            if (hoursEl) hoursEl.textContent = hours;
            if (minutesEl) minutesEl.textContent = minutes;

            const days = ['SUN', 'MON', 'TUE', 'WED', 'THU', 'FRI', 'SAT'];
            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, '0');
            const date = String(now.getDate()).padStart(2, '0');
            const day = days[now.getDay()];

            const dateEl = document.getElementById('date-full');
            if (dateEl) {
                dateEl.textContent = `${year} . ${month} . ${date} ${day}`;
            }

            const currentHour = now.getHours();
            let greeting = 'Evening';
            if (currentHour >= 5 && currentHour < 12) greeting = 'Morning';
            else if (currentHour >= 12 && currentHour < 18) greeting = 'Afternoon';

            const greetingEl = document.getElementById('greeting');
            if (greetingEl) greetingEl.textContent = greeting;
        }

        function renderCalendar(initialDate) {
            const titleEl = document.getElementById('calendar-title');
            const weekdaysEl = document.getElementById('calendar-weekdays');
            const daysEl = document.getElementById('calendar-days');
            const prevEl = document.getElementById('calendar-prev');
            const nextEl = document.getElementById('calendar-next');

            if (!titleEl || !weekdaysEl || !daysEl || !prevEl || !nextEl) return;

            const weekdayLabels = ['S', 'M', 'T', 'W', 'T', 'F', 'S'];
            weekdaysEl.innerHTML = weekdayLabels.map((label, index) => {
                const extra = index === 0 ? ' is-sun' : index === 6 ? ' is-sat' : '';
                return `<div class="calendar-weekday${extra}">${label}</div>`;
            }).join('');

            let current = new Date(initialDate.getFullYear(), initialDate.getMonth(), 1);

            const draw = () => {
                const today = new Date();
                const monthStart = new Date(current.getFullYear(), current.getMonth(), 1);
                const monthEnd = new Date(current.getFullYear(), current.getMonth() + 1, 0);
                const startWeekday = monthStart.getDay();
                const daysInMonth = monthEnd.getDate();
                const prevMonthEnd = new Date(current.getFullYear(), current.getMonth(), 0).getDate();
                const monthNames = [
                    'January', 'February', 'March', 'April', 'May', 'June',
                    'July', 'August', 'September', 'October', 'November', 'December'
                ];

                titleEl.textContent = `${monthNames[current.getMonth()]} ${current.getFullYear()}`;

                const cells = [];
                for (let i = startWeekday - 1; i >= 0; i -= 1) {
                    cells.push(`<div class="calendar-day is-muted">${prevMonthEnd - i}</div>`);
                }

                for (let day = 1; day <= daysInMonth; day += 1) {
                    const isToday =
                        today.getFullYear() === current.getFullYear() &&
                        today.getMonth() === current.getMonth() &&
                        today.getDate() === day;
                    cells.push(`<div class="calendar-day${isToday ? ' is-today' : ''}">${day}</div>`);
                }

                const remainder = cells.length % 7;
                const nextDays = remainder === 0 ? 0 : 7 - remainder;
                for (let day = 1; day <= nextDays; day += 1) {
                    cells.push(`<div class="calendar-day is-muted">${day}</div>`);
                }

                daysEl.innerHTML = cells.join('');
            };

            prevEl.addEventListener('click', () => {
                current = new Date(current.getFullYear(), current.getMonth() - 1, 1);
                draw();
            });

            nextEl.addEventListener('click', () => {
                current = new Date(current.getFullYear(), current.getMonth() + 1, 1);
                draw();
            });

            draw();
        }

        setInterval(updateClock, 1000);
        updateClock();
        renderCalendar(new Date());

        (() => {
            const likeButton = document.getElementById('home-like-pill');
            if (!likeButton) return;

            const icon = likeButton.querySelector('.heart-icon');
            const countEl = likeButton.querySelector('.like-count');
            const storageKey = likeButton.dataset.storageKey || 'sukiame:home-like:ui';
            const endpoint = likeButton.dataset.likeEndpoint || '/api/like/home-hero';
            const baseCount = Number(likeButton.dataset.likeCount || '0');
            let displayCount = baseCount;
            let liked = false;
            let pending = false;

            try {
                liked = window.localStorage.getItem(storageKey) === 'true';
            } catch (error) {}

            const render = () => {
                if (likeButton) likeButton.classList.toggle('is-liked', liked);
                if (likeButton) likeButton.setAttribute('aria-pressed', liked ? 'true' : 'false');
                if (likeButton) likeButton.disabled = pending;
                if (countEl) countEl.textContent = String(displayCount);
            };

            const animate = () => {
                [icon, countEl].forEach((element) => {
                    if (!element) return;
                    element.classList.remove('animating');
                    void element.offsetWidth;
                    element.classList.add('animating');
                });
            };

            const loadCount = async () => {
                try {
                    const response = await fetch(endpoint, {
                        headers: {
                            Accept: 'application/json'
                        }
                    });
                    if (!response.ok) {
                        throw new Error(`Request failed with ${response.status}`);
                    }
                    const payload = await response.json();
                    if (typeof payload.count === 'number' && Number.isFinite(payload.count)) {
                        displayCount = payload.count;
                        render();
                    }
                } catch (error) {
                    console.warn('[sukiame] Failed to load hero like count:', error.message);
                }
            };

            likeButton.addEventListener('click', async () => {
                if (liked || pending) {
                    animate();
                    return;
                }

                pending = true;
                render();

                try {
                    const response = await fetch(endpoint, {
                        method: 'POST',
                        headers: {
                            Accept: 'application/json'
                        }
                    });
                    const payload = await response.json().catch(() => ({}));
                    if (!response.ok) {
                        throw new Error(payload.error || `Request failed with ${response.status}`);
                    }

                    liked = true;
                    if (typeof payload.count === 'number' && Number.isFinite(payload.count)) {
                        displayCount = payload.count;
                    } else {
                        displayCount += 1;
                    }

                    try {
                        window.localStorage.setItem(storageKey, 'true');
                    } catch (error) {}

                    render();
                    animate();
                } catch (error) {
                    console.warn('[sukiame] Failed to submit hero like:', error.message);
                } finally {
                    pending = false;
                    render();
                }
            });

            if (liked && displayCount < 1) {
                displayCount = 1;
            }

            render();
            loadCount();
        })();

    </script>
    <script>
        (() => {
            if (window.__sukiamePjaxReady) return;
            window.__sukiamePjaxReady = true;

            const root = document.documentElement;
            const pageRootSelector = '#sukiame-page-root';
            const pageCache = new Map();
            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
            const EXIT_ANIMATION_MS = 1080;
            const ENTER_ANIMATION_MS = 640;
            const MAX_STAGGER_MS = 56;
            const NAVIGATION_DELAY_MS = prefersReducedMotion.matches ? 0 : 1000;
            let navigating = false;
            let navigationSerial = 0;

            const transitionTargetsByShell = {
                'home-shell': [
                    '.profile-panel',
                    '.nav-panel',
                    '.hero-panel',
                    '.latest-panel',
                    '.photo-panel',
                    '.activity-panel',
                    '.clock-panel',
                    '.calendar-panel',
                    '.visitors-panel'
                ],
                'blog-shell': [
                    '.blog-dock',
                    '.blog-status',
                    '.blog-hero',
                    '.blog-panel'
                ],
                'post-shell': [
                    '.post-dock',
                    '.post-status',
                    '.post-hero',
                    '.post-panel'
                ],
                'note-shell': [
                    '.note-dock',
                    '.note-status',
                    '.note-hero',
                    '.note-panel'
                ],
                'friends-shell': [
                    '.friends-dock',
                    '.friends-status',
                    '.friends-hero',
                    '.friends-panel'
                ],
                'photo-wall-shell': [
                    '.photo-wall-dock',
                    '.photo-wall-status',
                    '.photo-wall-board'
                ],
                'guestbook-shell': [
                    '.guestbook-dock',
                    '.guestbook-status',
                    '.guestbook-board'
                ]
            };

            const transientRootClasses = [
                'is-page-navigating',
                'is-page-enter-prep',
                'is-page-entering'
            ];

            const transientBodyClasses = [
                'is-page-leaving',
                'photo-wall-lightbox-open',
                'guestbook-lightbox-open',
                'guestbook-composer-open'
            ];

            const wait = (duration) => new Promise((resolve) => window.setTimeout(resolve, duration));

            const afterNextPaint = (callback) => {
                window.requestAnimationFrame(() => {
                    window.requestAnimationFrame(callback);
                });
            };

            const getPageRoot = () => document.querySelector(pageRootSelector);

            const getShell = () => document.querySelector(`${pageRootSelector} .home-shell, ${pageRootSelector} .blog-shell, ${pageRootSelector} .post-shell, ${pageRootSelector} .note-shell, ${pageRootSelector} .friends-shell, ${pageRootSelector} .photo-wall-shell, ${pageRootSelector} .guestbook-shell`);

            const getTransitionTargets = () => {
                const shell = getShell();
                if (!shell) return [];

                const activeTargetSelector = Object.entries(transitionTargetsByShell)
                    .find(([className]) => shell.classList.contains(className))?.[1]?.join(', ');

                if (!activeTargetSelector) return [];

                return Array.from(shell.querySelectorAll(activeTargetSelector))
                    .filter((element) => !element.closest('.photo-wall-lightbox, .guestbook-lightbox, .guestbook-composer'));
            };

            const applyTransitionVectors = (targets) => {
                if (!targets.length) return;

                const viewportCenterX = window.innerWidth / 2;
                const viewportCenterY = window.innerHeight / 2;
                const viewportRadius = Math.hypot(viewportCenterX, viewportCenterY);
                const fallbackAngleStep = (Math.PI * 2) / Math.max(targets.length, 1);

                targets.forEach((element, index) => {
                    const rect = element.getBoundingClientRect();
                    const centerX = rect.left + rect.width / 2;
                    const centerY = rect.top + rect.height / 2;
                    const deltaX = centerX - viewportCenterX;
                    const deltaY = centerY - viewportCenterY;
                    const magnitude = Math.hypot(deltaX, deltaY);
                    const angle = magnitude > 1
                        ? Math.atan2(deltaY, deltaX)
                        : (fallbackAngleStep * index) - (Math.PI / 2);
                    const radialX = Math.cos(angle);
                    const radialY = Math.sin(angle);
                    const travelDistance = viewportRadius + Math.max(rect.width, rect.height) * 0.62 + 150 + magnitude * 0.2;
                    const midDistance = travelDistance * 0.56;
                    const exitX = radialX * travelDistance;
                    const exitY = radialY * travelDistance;
                    const midX = radialX * midDistance;
                    const midY = radialY * midDistance;
                    const rotateSign = radialX === 0 ? (radialY >= 0 ? 1 : -1) : Math.sign(radialX);
                    const rotate = rotateSign * (4 + Math.min((magnitude / Math.max(viewportRadius, 1)) * 4.5, 4.5));
                    const midRotate = rotate * 0.46;
                    const enterDistance = Math.min(76, 42 + magnitude * 0.075);
                    const enterX = radialX * enterDistance;
                    const enterY = radialY * enterDistance;
                    const enterRotate = rotate * 0.34;
                    const normalizedDistance = magnitude / Math.max(viewportRadius, 1);
                    const delay = prefersReducedMotion.matches ? 0 : Math.pow(normalizedDistance, 1.12) * MAX_STAGGER_MS;
                    const scale = Math.max(0.91, 0.972 - normalizedDistance * 0.024);

                    element.classList.add('page-transition-target');
                    element.style.setProperty('--page-transition-index', index);
                    element.style.setProperty('--page-exit-duration', `${EXIT_ANIMATION_MS}ms`);
                    element.style.setProperty('--page-enter-duration', `${ENTER_ANIMATION_MS}ms`);
                    element.style.setProperty('--page-transition-delay', `${delay.toFixed(0)}ms`);
                    element.style.setProperty('--page-exit-mid-x', `${midX.toFixed(2)}px`);
                    element.style.setProperty('--page-exit-mid-y', `${midY.toFixed(2)}px`);
                    element.style.setProperty('--page-exit-x', `${exitX.toFixed(2)}px`);
                    element.style.setProperty('--page-exit-y', `${exitY.toFixed(2)}px`);
                    element.style.setProperty('--page-exit-mid-rotate', `${midRotate.toFixed(2)}deg`);
                    element.style.setProperty('--page-exit-rotate', `${rotate.toFixed(2)}deg`);
                    element.style.setProperty('--page-enter-x', `${enterX.toFixed(2)}px`);
                    element.style.setProperty('--page-enter-y', `${enterY.toFixed(2)}px`);
                    element.style.setProperty('--page-enter-rotate', `${enterRotate.toFixed(2)}deg`);
                    element.style.setProperty('--page-exit-scale', scale.toFixed(3));
                });
            };

            const cleanTransientState = () => {
                root.classList.remove(...transientRootClasses);
                document.body.classList.remove(...transientBodyClasses);
            };

            const getLinkUrl = (event) => {
                if (event.defaultPrevented) return null;
                if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return null;

                const target = event.target instanceof Element ? event.target : null;
                const link = target ? target.closest('a') : null;
                if (!link) return null;
                if (link.target === '_blank' || link.hasAttribute('download') || link.dataset.noPjax === 'true') return null;

                const href = link.getAttribute('href') || '';
                if (!href || href.startsWith('#') || /^(?:mailto|tel|javascript):/i.test(href)) return null;

                const url = new URL(link.href, window.location.href);
                if (url.origin !== window.location.origin) return null;
                if (url.pathname === window.location.pathname && url.search === window.location.search) return null;
                if (/^\/(?:api|images|cursors|vendor)\//.test(url.pathname)) return null;
                if (url.pathname.endsWith('/atom.xml')) return null;

                const extensionMatch = url.pathname.match(/\.([a-z0-9]+)$/i);
                if (extensionMatch && extensionMatch[1].toLowerCase() !== 'html') return null;

                return url;
            };

            const fetchPage = (url) => {
                const key = url.href;
                if (!pageCache.has(key)) {
                    pageCache.set(key, fetch(key, {
                        credentials: 'same-origin',
                        headers: {
                            Accept: 'text/html,application/xhtml+xml'
                        }
                    }).then(async (response) => {
                        if (!response.ok) {
                            throw new Error(`Request failed with ${response.status}`);
                        }

                        const type = response.headers.get('content-type') || '';
                        if (type && !type.includes('text/html')) {
                            throw new Error(`Unsupported content type: ${type}`);
                        }

                        return new DOMParser().parseFromString(await response.text(), 'text/html');
                    }).catch((error) => {
                        pageCache.delete(key);
                        throw error;
                    }));
                }

                return pageCache.get(key);
            };

            const prefetchPage = (url) => {
                if (!url || pageCache.has(url.href)) return;
                fetchPage(url).catch(() => {});
            };

            const executePageScripts = (container) => {
                const scripts = Array.from(container.querySelectorAll('script'));
                if (!scripts.length) return;

                const pageScope = window.__sukiamePageScope;
                if (pageScope) pageScope.begin();

                try {
                    scripts.forEach((script) => {
                        const executable = document.createElement('script');

                        Array.from(script.attributes).forEach((attribute) => {
                            executable.setAttribute(attribute.name, attribute.value);
                        });

                        if (!executable.src) {
                            executable.textContent = script.textContent || '';
                        }

                        script.parentNode.replaceChild(executable, script);
                    });
                } finally {
                    if (pageScope) pageScope.end();
                }
            };

            const initHomeLike = () => {
                const likeButton = document.getElementById('home-like-pill');
                if (!likeButton || likeButton.dataset.sukiameLikeReady === 'true') return;

                const icon = likeButton.querySelector('.heart-icon');
                const countEl = likeButton.querySelector('.like-count');
                const storageKey = likeButton.dataset.storageKey || 'sukiame:home-like:ui';
                const endpoint = likeButton.dataset.likeEndpoint || '/api/like/home-hero';
                const baseCount = Number(likeButton.dataset.likeCount || '0');
                let displayCount = baseCount;
                let liked = false;
                let pending = false;

                likeButton.dataset.sukiameLikeReady = 'true';

                try {
                    liked = window.localStorage.getItem(storageKey) === 'true';
                } catch (error) {}

                const render = () => {
                    likeButton.classList.toggle('is-liked', liked);
                    likeButton.setAttribute('aria-pressed', liked ? 'true' : 'false');
                    likeButton.disabled = pending;
                    if (countEl) countEl.textContent = String(displayCount);
                };

                const animate = () => {
                    [icon, countEl].forEach((element) => {
                        if (!element) return;
                        element.classList.remove('animating');
                        void element.offsetWidth;
                        element.classList.add('animating');
                    });
                };

                const loadCount = async () => {
                    try {
                        const response = await fetch(endpoint, {
                            headers: {
                                Accept: 'application/json'
                            }
                        });
                        if (!response.ok) {
                            throw new Error(`Request failed with ${response.status}`);
                        }
                        const payload = await response.json();
                        if (typeof payload.count === 'number' && Number.isFinite(payload.count)) {
                            displayCount = payload.count;
                            render();
                        }
                    } catch (error) {
                        console.warn('[sukiame] Failed to load hero like count:', error.message);
                    }
                };

                likeButton.addEventListener('click', async () => {
                    if (liked || pending) {
                        animate();
                        return;
                    }

                    pending = true;
                    render();

                    try {
                        const response = await fetch(endpoint, {
                            method: 'POST',
                            headers: {
                                Accept: 'application/json'
                            }
                        });
                        const payload = await response.json().catch(() => ({}));
                        if (!response.ok) {
                            throw new Error(payload.error || `Request failed with ${response.status}`);
                        }

                        liked = true;
                        if (typeof payload.count === 'number' && Number.isFinite(payload.count)) {
                            displayCount = payload.count;
                        } else {
                            displayCount += 1;
                        }

                        try {
                            window.localStorage.setItem(storageKey, 'true');
                        } catch (error) {}

                        render();
                        animate();
                    } catch (error) {
                        console.warn('[sukiame] Failed to submit hero like:', error.message);
                    } finally {
                        pending = false;
                        render();
                    }
                });

                if (liked && displayCount < 1) {
                    displayCount = 1;
                }

                render();
                loadCount();
            };

            const refreshVisitorCounter = () => {
                const candidates = [window.BUSUANZI, window.Busuanzi, window.busuanzi, window.bszCaller];
                const counter = candidates.find((item) => item && typeof item.fetch === 'function');
                if (counter) {
                    try {
                        counter.fetch();
                    } catch (error) {}
                }
            };

            const initLayoutWidgets = () => {
                if (typeof updateClock === 'function') updateClock();
                if (typeof renderCalendar === 'function') renderCalendar(new Date());
                initHomeLike();
                refreshVisitorCounter();
            };

            window.__sukiameInitPageWidgets = initLayoutWidgets;

            const restoreScroll = (url) => {
                if (url.hash) {
                    let targetId = url.hash.slice(1);
                    try {
                        targetId = decodeURIComponent(targetId);
                    } catch (error) {}
                    const target = document.getElementById(targetId);
                    if (target) {
                        target.scrollIntoView();
                        return;
                    }
                }

                window.scrollTo(0, 0);
            };

            const finishEnterAnimation = (serial) => {
                window.setTimeout(() => {
                    if (serial !== navigationSerial) return;
                    root.classList.remove('is-page-entering', 'is-page-enter-prep', 'is-page-navigating');
                    document.body.classList.remove('is-page-leaving');
                    navigating = false;
                }, ENTER_ANIMATION_MS + MAX_STAGGER_MS + 120);
            };

            const navigateTo = async (url, options = {}) => {
                if (navigating) return;

                const serial = ++navigationSerial;
                navigating = true;

                root.classList.remove('is-page-entering', 'is-page-enter-prep');
                root.classList.add('is-page-navigating');
                applyTransitionVectors(getTransitionTargets());

                afterNextPaint(() => {
                    if (serial === navigationSerial) {
                        document.body.classList.add('is-page-leaving');
                    }
                });

                try {
                    const [nextDocument] = await Promise.all([
                        fetchPage(url),
                        wait(NAVIGATION_DELAY_MS)
                    ]);

                    if (serial !== navigationSerial) return;

                    const currentPageRoot = getPageRoot();
                    const nextPageRoot = nextDocument.querySelector(pageRootSelector);
                    if (!currentPageRoot || !nextPageRoot) {
                        window.location.href = url.href;
                        return;
                    }

                    if (window.__sukiameClearPageScope) {
                        window.__sukiameClearPageScope();
                    }

                    document.title = nextDocument.title || document.title;
                    document.body.className = nextDocument.body.className || '';
                    root.classList.remove(...transientRootClasses);
                    root.classList.add('is-page-enter-prep');
                    currentPageRoot.innerHTML = nextPageRoot.innerHTML;

                    executePageScripts(currentPageRoot);
                    initLayoutWidgets();
                    applyTransitionVectors(getTransitionTargets());

                    if (options.history !== false) {
                        window.history.pushState({ sukiamePjax: true }, '', url.href);
                    }

                    restoreScroll(url);

                    afterNextPaint(() => {
                        if (serial !== navigationSerial) return;
                        root.classList.remove('is-page-enter-prep');
                        root.classList.add('is-page-entering');
                        document.dispatchEvent(new CustomEvent('sukiame:page-ready', {
                            detail: {
                                url: url.href
                            }
                        }));
                    });

                    finishEnterAnimation(serial);
                } catch (error) {
                    console.warn('[sukiame] PJAX navigation failed, falling back:', error.message);
                    window.location.href = url.href;
                }
            };

            document.addEventListener('click', (event) => {
                const url = getLinkUrl(event);
                if (!url) return;

                event.preventDefault();
                event.stopImmediatePropagation();
                navigateTo(url);
            }, true);

            document.addEventListener('pointerenter', (event) => {
                const url = getLinkUrl(event);
                if (!url) return;
                prefetchPage(url);
            }, true);

            window.addEventListener('popstate', () => {
                cleanTransientState();
                navigateTo(new URL(window.location.href), { history: false });
            });

            window.addEventListener('pageshow', () => {
                cleanTransientState();
                navigating = false;
            });

            window.addEventListener('resize', () => {
                if (!navigating) {
                    applyTransitionVectors(getTransitionTargets());
                }
            });

            window.history.replaceState({ sukiamePjax: true }, '', window.location.href);
        })();
    </script>
</body>

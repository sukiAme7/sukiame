<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%- page.title || config.title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=ZCOOL+KuaiLe&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Nunito', 'sans-serif'],
                        cute: ['ZCOOL KuaiLe', 'cursive'],
                    },
                    colors: {
                        'rain-light': '#e0f2fe',
                        'rain-blue': '#7dd3fc',
                        'rain-dark': '#0369a1',
                    }
                }
            }
        }
    </script>
    <style>
        :root {
            --card-bg: rgba(255, 255, 255, 0.4);
            --card-bg-hover: rgba(255, 255, 255, 0.55);
            --card-border: rgba(255, 255, 255, 0.8);
            --text-main: #334155;
            --text-soft: #64748b;
            --text-muted: #94a3b8;
            --rain-blue: #7dd3fc;
            --rain-dark: #0369a1;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(-45deg, #e0f2fe, #bae6fd, #f3e8ff, #e0e7ff);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
            color: var(--text-main);
            font-family: 'Nunito', sans-serif;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        button {
            border: 0;
            background: transparent;
            cursor: pointer;
            font: inherit;
        }

        .home-shell {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
            position: relative;
            overflow-x: hidden;
        }

        .home-grid {
            width: min(1350px, 100%);
            display: grid;
            grid-template-columns: repeat(12, minmax(0, 1fr));
            gap: 2rem;
            align-items: start;
            margin: auto 0;
            position: relative;
            z-index: 1;
        }

        .left-column,
        .center-column,
        .right-column {
            display: flex;
            flex-direction: column;
            gap: 1.75rem;
        }

        .right-column {
            gap: 0;
            align-self: stretch;
            justify-content: space-between;
            height: 100%;
        }

        .left-column { grid-column: span 3 / span 3; }
        .center-column { grid-column: span 6 / span 6; }
        .right-column { grid-column: span 3 / span 3; }

        .glass-card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--card-border);
            border-right: 1px solid rgba(255, 255, 255, 0.4);
            border-bottom: 1px solid rgba(255, 255, 255, 0.4);
            border-radius: 1.5rem;
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.04);
            transition: all 0.3s ease;
        }

        .glass-card:hover {
            background: var(--card-bg-hover);
            box-shadow: 0 12px 40px 0 rgba(31, 38, 135, 0.08);
            transform: translateY(-2px);
        }

        .profile-panel {
            min-height: 310px;
            padding: 2rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .profile-avatar-box {
            position: relative;
            width: 6rem;
            height: 6rem;
            margin-bottom: 1.25rem;
            cursor: pointer;
        }

        .profile-avatar {
            width: 100%;
            height: 100%;
            border-radius: 999px;
            object-fit: cover;
            border: 3px solid #fff;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.12);
            transition: transform 0.7s ease;
        }

        .profile-avatar-box:hover .profile-avatar {
            transform: rotate(360deg);
        }

        .profile-status {
            position: absolute;
            right: 0;
            bottom: 0;
            width: 1.25rem;
            height: 1.25rem;
            border-radius: 999px;
            background: #4ade80;
            border: 2px solid #fff;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.08);
        }

        .profile-title {
            margin: 0;
            font-size: 2rem;
            line-height: 1;
            color: #1e293b;
            letter-spacing: 0.03em;
        }

        .profile-subtitle {
            margin: 0.75rem 0 0;
            font-size: 13px;
            color: #64748b;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.375rem;
        }

        .profile-actions {
            width: 100%;
            display: flex;
            justify-content: center;
            gap: 1rem;
            margin-top: 1.25rem;
        }

        .profile-actions a {
            width: 2.25rem;
            height: 2.25rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.6);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #64748b;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.06);
            transition: all 0.25s ease;
        }

        .profile-actions a:hover {
            background: #fff;
            transform: translateY(-4px);
        }

        .nav-panel {
            position: relative;
            overflow: hidden;
            min-height: 330px;
            padding: 1.5rem 1.25rem;
            display: flex;
            flex-direction: column;
        }

        .nav-panel-icon {
            position: absolute;
            top: -1.5rem;
            right: -1.5rem;
            font-size: 5.5rem;
            color: rgba(255, 255, 255, 0.3);
            pointer-events: none;
        }

        .section-kicker {
            margin: 0 0 1.25rem;
            padding-left: 0.5rem;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #94a3b8;
            position: relative;
            z-index: 1;
        }

        .nav-links {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .nav-link {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.875rem;
            border-radius: 0.875rem;
            color: #64748b;
            transition: all 0.25s ease;
        }

        .nav-link:hover {
            background: rgba(255, 255, 255, 0.6);
            color: #1e293b;
        }

        .active-nav {
            background: #fff;
            border-left: 4px solid #0369a1;
            border-radius: 6px 14px 14px 6px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
            color: #0369a1;
        }

        .nav-link-label {
            display: flex;
            align-items: center;
            gap: 1rem;
            font-size: 15px;
            font-weight: 700;
        }

        .nav-link-label i {
            width: 1.5rem;
            text-align: center;
            font-size: 1.125rem;
        }

        .nav-link-arrow {
            color: #94a3b8;
            font-size: 0.875rem;
            transition: color 0.25s ease;
        }

        .nav-link:hover .nav-link-arrow {
            color: #334155;
        }

        .nav-link-arrow-fade {
            opacity: 0;
            transition: opacity 0.25s ease;
        }

        .nav-link:hover .nav-link-arrow-fade {
            opacity: 1;
        }

        .hero-panel {
            min-height: 310px;
            padding: 2.5rem;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .hero-illustration {
            position: absolute;
            right: -1rem;
            bottom: -1rem;
            font-size: 13rem;
            color: rgba(255, 255, 255, 0.4);
            pointer-events: none;
            transition: transform 0.7s ease;
        }

        .hero-panel:hover .hero-illustration {
            transform: scale(1.1);
        }

        .hero-content {
            position: relative;
            z-index: 1;
        }

        .hero-greeting {
            margin: 0 0 0.5rem;
            font-size: 1.25rem;
            color: #64748b;
            font-weight: 700;
        }

        .hero-title {
            margin: 0 0 1rem;
            font-size: clamp(2.5rem, 6vw, 3.5rem);
            line-height: 1.1;
            font-weight: 900;
            color: #1e293b;
        }

        .hero-name {
            background: linear-gradient(to right, #0369a1, #3b82f6, #8b5cf6);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            letter-spacing: 0.05em;
            padding-bottom: 0.125rem;
        }

        .hero-copy {
            margin: 0;
            max-width: 34rem;
            padding-left: 1rem;
            border-left: 4px solid #7dd3fc;
            color: #64748b;
            font-size: 1rem;
            line-height: 1.75;
            font-weight: 600;
        }

        .center-bottom-grid {
            min-height: 330px;
            display: grid;
            grid-template-columns: repeat(5, minmax(0, 1fr));
            gap: 1.75rem;
        }

        .latest-panel {
            grid-column: span 3 / span 3;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            min-height: 330px;
        }

        .panel-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.25rem;
        }

        .panel-title {
            margin: 0;
            font-size: 15px;
            font-weight: 800;
            color: #334155;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .panel-title-bar {
            width: 0.25rem;
            height: 1rem;
            border-radius: 999px;
            background: #7dd3fc;
        }

        .panel-link {
            font-size: 10px;
            color: #94a3b8;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .post-list {
            display: flex;
            flex-direction: column;
            gap: 0.625rem;
        }

        .post-row {
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            padding: 0.75rem;
            border-radius: 0.75rem;
            transition: background 0.25s ease;
        }

        .post-row:hover {
            background: rgba(255, 255, 255, 0.6);
        }

        .post-icon {
            width: 3rem;
            height: 3rem;
            border-radius: 0.75rem;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }

        .post-row:hover .post-icon {
            color: #fff;
        }

        .post-icon-blue {
            background: rgba(239, 246, 255, 0.8);
            color: #3b82f6;
        }

        .post-row:hover .post-icon-blue {
            background: #3b82f6;
        }

        .post-icon-green {
            background: rgba(240, 253, 244, 0.8);
            color: #22c55e;
        }

        .post-row:hover .post-icon-green {
            background: #22c55e;
        }

        .post-icon-purple {
            background: rgba(245, 243, 255, 0.8);
            color: #a855f7;
        }

        .post-row:hover .post-icon-purple {
            background: #a855f7;
        }

        .post-text {
            min-width: 0;
            flex: 1;
            padding-top: 0.125rem;
        }

        .post-title {
            margin: 0 0 0.25rem;
            font-size: 0.875rem;
            font-weight: 700;
            color: #334155;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .post-excerpt {
            margin: 0;
            font-size: 11px;
            color: #64748b;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .post-date {
            flex-shrink: 0;
            font-size: 10px;
            font-weight: 700;
            color: #94a3b8;
            padding-top: 0.375rem;
        }

        .side-stack {
            grid-column: span 2 / span 2;
            min-height: 330px;
            display: flex;
            flex-direction: column;
            gap: 1.75rem;
        }

        .photo-panel,
        .stack-panel {
            min-height: 140px;
            padding: 1.25rem;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .photo-glow,
        .stack-glow {
            position: absolute;
            right: -20px;
            bottom: -20px;
            width: 6rem;
            height: 6rem;
            border-radius: 999px;
            filter: blur(32px);
            opacity: 0.4;
            transition: opacity 0.25s ease;
            pointer-events: none;
        }

        .photo-glow {
            background: linear-gradient(to bottom right, #d8b4fe, #f3e8ff);
        }

        .stack-glow {
            background: linear-gradient(to bottom right, #5eead4, #d1fae5);
        }

        .photo-panel:hover .photo-glow,
        .stack-panel:hover .stack-glow {
            opacity: 0.8;
        }

        .photo-shot {
            position: absolute;
            background: #fff;
            padding: 2px;
            border-radius: 0.125rem;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.12);
            z-index: 0;
            transition: all 0.5s ease;
        }

        .photo-shot::after {
            content: "";
            display: block;
            width: 100%;
            height: 100%;
            border-radius: 0.125rem;
            background: linear-gradient(135deg, #8ec5ff, #2d3f59);
        }

        .photo-shot-one {
            right: 0.75rem;
            top: 0.75rem;
            width: 2.5rem;
            height: 2.5rem;
            transform: rotate(12deg);
        }

        .photo-shot-two {
            right: 2.5rem;
            top: 1.5rem;
            width: 2rem;
            height: 2rem;
            transform: rotate(-6deg);
        }

        .photo-panel:hover .photo-shot-one {
            transform: rotate(24deg) scale(1.1) translateY(-4px);
        }

        .photo-panel:hover .photo-shot-two {
            transform: rotate(-12deg) translateX(-8px);
        }

        .photo-badge {
            width: 2.5rem;
            height: 2.5rem;
            border-radius: 999px;
            background: #fff;
            color: #a855f7;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.08);
            position: relative;
            z-index: 1;
            transition: transform 0.25s ease;
        }

        .photo-panel:hover .photo-badge {
            transform: scale(1.1);
        }

        .photo-copy,
        .stack-head {
            position: relative;
            z-index: 1;
            text-align: center;
        }

        .photo-copy h3,
        .stack-head h3 {
            margin: 0;
            font-size: 1rem;
            font-weight: 800;
            color: #1e293b;
        }

        .photo-copy p,
        .stack-head p {
            margin: 0.25rem 0 0;
            font-size: 11px;
            color: #64748b;
            font-weight: 600;
        }

        .stack-head p {
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-size: 10px;
            font-weight: 700;
        }

        .stack-grid {
            position: relative;
            z-index: 1;
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 0.375rem;
            width: 100%;
        }

        .photo-panel {
            align-items: center;
            text-align: center;
        }

        .photo-badge {
            margin-bottom: 1rem;
        }

        .photo-copy {
            margin-top: 0.5rem;
        }

        .stack-panel {
            align-items: center;
            text-align: center;
        }

        .stack-head {
            margin-bottom: 1rem;
        }

        .stack-grid {
            max-width: 14rem;
            margin: 0 auto;
        }

        .stack-tile {
            aspect-ratio: 1 / 1;
            border-radius: 0.625rem;
            background: rgba(255, 255, 255, 0.7);
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.06);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.95rem;
            transition: transform 0.3s ease;
        }

        .stack-panel:hover .stack-tile {
            transform: translateY(-4px);
        }

        .stack-tile.html { color: #e34f26; }
        .stack-tile.css { color: #1572b6; }
        .stack-tile.js { color: #f7df1e; }
        .stack-tile.vue { color: #41b883; }

        .clock-panel,
        .calendar-panel {
            flex-shrink: 0;
        }

        .clock-panel {
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .clock-display {
            display: flex;
            align-items: baseline;
            justify-content: center;
            gap: 0.5rem;
        }

        .clock-display span {
            font-size: 3rem;
            font-weight: 900;
            color: #334155;
            letter-spacing: -0.04em;
        }

        .clock-separator {
            font-size: 1.875rem;
            color: #93c5fd;
            position: relative;
            top: -0.25rem;
            animation: pulse 2s ease-in-out infinite;
        }

        .clock-meta {
            margin-top: 0.75rem;
            font-size: 10px;
            font-weight: 800;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #94a3b8;
        }

        .calendar-panel {
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }

        .calendar-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.25rem;
        }

        .calendar-month {
            font-size: 0.875rem;
            font-weight: 900;
            color: #334155;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }

        .calendar-arrows {
            display: flex;
            gap: 0.375rem;
        }

        .calendar-arrow {
            width: 1.5rem;
            height: 1.5rem;
            border-radius: 0.375rem;
            background: rgba(255, 255, 255, 0.6);
            color: #94a3b8;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 8px rgba(15, 23, 42, 0.06);
            transition: all 0.25s ease;
        }

        .calendar-arrow:hover {
            color: #334155;
            background: #fff;
        }

        .calendar-weekdays,
        .calendar-days {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            text-align: center;
            font-size: 11px;
        }

        .calendar-weekdays {
            gap: 0.25rem;
            margin-bottom: 0.5rem;
        }

        .calendar-weekday {
            font-weight: 700;
            color: #94a3b8;
            margin-bottom: 0.25rem;
        }

        .calendar-weekday.is-sun { color: #f472b6; font-weight: 900; }
        .calendar-weekday.is-sat { color: #60a5fa; font-weight: 900; }

        .calendar-days {
            gap: 0.5rem 0.25rem;
        }

        .calendar-day {
            aspect-ratio: 1 / 1;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
            color: #475569;
            border-radius: 0.625rem;
            transition: color 0.25s ease, box-shadow 0.25s ease;
        }

        .calendar-day:hover {
            color: #0369a1;
        }

        .calendar-day.is-muted {
            color: #cbd5e1;
            font-weight: 500;
        }

        .calendar-day.is-today {
            background: linear-gradient(to bottom right, #60a5fa, #6366f1);
            color: #fff;
            font-weight: 900;
            box-shadow: 0 8px 18px rgba(99, 102, 241, 0.25);
        }

        .visitors-panel {
            padding: 1.5rem;
            min-height: 140px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
            overflow: hidden;
            margin-top: 0;
        }

        .visitors-kicker {
            padding-left: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .visitors-kicker i {
            color: #cbd5e1;
        }

        .visitors-core {
            margin-top: 0.2rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            min-height: 4.25rem;
        }

        .visitors-badge {
            width: 3rem;
            height: 3rem;
            border-radius: 1rem;
            background: rgba(255, 255, 255, 0.72);
            color: #3b82f6;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            box-shadow: 0 8px 24px rgba(59, 130, 246, 0.1);
        }

        .visitors-metric {
            display: flex;
            flex-direction: column;
        }

        .visitors-metric strong {
            font-size: 2rem;
            line-height: 1;
            color: #1e293b;
            font-weight: 900;
        }

        .visitors-metric span {
            margin-top: 0.25rem;
            font-size: 0.76rem;
            color: #64748b;
            font-weight: 700;
        }

        ::-webkit-scrollbar {
            width: 4px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(125, 211, 252, 0.8);
            border-radius: 10px;
        }

        @media (max-width: 1024px) {
            .home-grid {
                grid-template-columns: 1fr;
            }

            .left-column,
            .center-column,
            .right-column {
                grid-column: auto;
            }

            .center-bottom-grid {
                grid-template-columns: 1fr;
            }

            .latest-panel,
            .side-stack {
                grid-column: auto;
            }
        }

        @media (max-width: 768px) {
            .home-shell {
                padding: 1rem;
            }

            .home-grid,
            .left-column,
            .center-column,
            .right-column,
            .side-stack {
                gap: 1.5rem;
            }

            .hero-panel,
            .profile-panel,
            .nav-panel,
            .latest-panel {
                min-height: auto;
            }

            .hero-panel {
                padding: 2rem 1.5rem;
            }

            .hero-illustration {
                font-size: 9rem;
                right: -1rem;
                bottom: -1.5rem;
            }
        }
    </style>
</head>
<body>
    <%- body %>

    <script>
        function updateClock() {
            const now = new Date();
            const hours = String(now.getHours()).padStart(2, '0');
            const minutes = String(now.getMinutes()).padStart(2, '0');

            const hoursEl = document.getElementById('time-hours');
            const minutesEl = document.getElementById('time-minutes');
            if (hoursEl) hoursEl.textContent = hours;
            if (minutesEl) minutesEl.textContent = minutes;

            const days = ['SUN', 'MON', 'TUE', 'WED', 'THU', 'FRI', 'SAT'];
            const year = now.getFullYear();
            const month = String(now.getMonth() + 1).padStart(2, '0');
            const date = String(now.getDate()).padStart(2, '0');
            const day = days[now.getDay()];

            const dateEl = document.getElementById('date-full');
            if (dateEl) {
                dateEl.textContent = `${year} . ${month} . ${date} ${day}`;
            }

            const currentHour = now.getHours();
            let greeting = 'Evening';
            if (currentHour >= 5 && currentHour < 12) greeting = 'Morning';
            else if (currentHour >= 12 && currentHour < 18) greeting = 'Afternoon';

            const greetingEl = document.getElementById('greeting');
            if (greetingEl) greetingEl.textContent = greeting;
        }

        function renderCalendar(initialDate) {
            const titleEl = document.getElementById('calendar-title');
            const weekdaysEl = document.getElementById('calendar-weekdays');
            const daysEl = document.getElementById('calendar-days');
            const prevEl = document.getElementById('calendar-prev');
            const nextEl = document.getElementById('calendar-next');

            if (!titleEl || !weekdaysEl || !daysEl || !prevEl || !nextEl) return;

            const weekdayLabels = ['S', 'M', 'T', 'W', 'T', 'F', 'S'];
            weekdaysEl.innerHTML = weekdayLabels.map((label, index) => {
                const extra = index === 0 ? ' is-sun' : index === 6 ? ' is-sat' : '';
                return `<div class="calendar-weekday${extra}">${label}</div>`;
            }).join('');

            let current = new Date(initialDate.getFullYear(), initialDate.getMonth(), 1);

            const draw = () => {
                const today = new Date();
                const monthStart = new Date(current.getFullYear(), current.getMonth(), 1);
                const monthEnd = new Date(current.getFullYear(), current.getMonth() + 1, 0);
                const startWeekday = monthStart.getDay();
                const daysInMonth = monthEnd.getDate();
                const prevMonthEnd = new Date(current.getFullYear(), current.getMonth(), 0).getDate();
                const monthNames = [
                    'January', 'February', 'March', 'April', 'May', 'June',
                    'July', 'August', 'September', 'October', 'November', 'December'
                ];

                titleEl.textContent = `${monthNames[current.getMonth()]} ${current.getFullYear()}`;

                const cells = [];
                for (let i = startWeekday - 1; i >= 0; i -= 1) {
                    cells.push(`<div class="calendar-day is-muted">${prevMonthEnd - i}</div>`);
                }

                for (let day = 1; day <= daysInMonth; day += 1) {
                    const isToday =
                        today.getFullYear() === current.getFullYear() &&
                        today.getMonth() === current.getMonth() &&
                        today.getDate() === day;
                    cells.push(`<div class="calendar-day${isToday ? ' is-today' : ''}">${day}</div>`);
                }

                const remainder = cells.length % 7;
                const nextDays = remainder === 0 ? 0 : 7 - remainder;
                for (let day = 1; day <= nextDays; day += 1) {
                    cells.push(`<div class="calendar-day is-muted">${day}</div>`);
                }

                daysEl.innerHTML = cells.join('');
            };

            prevEl.addEventListener('click', () => {
                current = new Date(current.getFullYear(), current.getMonth() - 1, 1);
                draw();
            });

            nextEl.addEventListener('click', () => {
                current = new Date(current.getFullYear(), current.getMonth() + 1, 1);
                draw();
            });

            draw();
        }

        setInterval(updateClock, 1000);
        updateClock();
        renderCalendar(new Date());
    </script>
</body>
</html>

  }
  .post-body figure.highlight table {
    width: 100%;
    border-spacing: 0;
    border-collapse: collapse;
  }
  .post-body figure.highlight td { vertical-align: top; }
  .post-body figure.highlight .gutter {
    width: 2.9rem;
    padding: 0.84rem 0.75rem 0.84rem 0.95rem;

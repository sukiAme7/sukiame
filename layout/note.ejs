    overflow: hidden;
    font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei UI', 'Microsoft YaHei', 'Noto Sans CJK SC', sans-serif;
  }

  .note-shell::before,
  .note-shell::after {
    content: "";
    position: absolute;
    inset: -12%;
    pointer-events: none;
  }

  .note-shell::before {
    background:
      radial-gradient(circle at 16% 14%, rgba(255, 255, 255, 0.74), transparent 24%),
      radial-gradient(circle at 84% 12%, rgba(251, 191, 36, 0.12), transparent 24%),
      radial-gradient(circle at 72% 82%, rgba(191, 219, 254, 0.16), transparent 26%),
      radial-gradient(circle at 18% 82%, rgba(226, 232, 240, 0.28), transparent 24%);

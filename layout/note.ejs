  @media (max-width: 768px) {
    .note-shell { padding: 1rem 0.95rem 2rem; }
    .note-dock,
    .note-status {
      position: relative;
      top: auto;
      left: auto;
      right: auto;
      margin-bottom: 0.85rem;
    }
    .note-dock { width: fit-content; }
    .note-grid { padding-top: 0.2rem; }
    .note-panel,
    .note-hero { padding: 1.15rem 1.1rem; }
    .note-reading-panel .post-body {
      padding: 1.8rem 1.15rem 2.3rem;
      font-size: 1rem;
      line-height: 1.95;
    }
  }

  @media (max-width: 640px) {
    .note-dock {
      width: 100%;
      justify-content: space-between;
      gap: 0.4rem;
    }
    .dock-avatar,
    .dock-link {
      width: 2.1rem;
      height: 2.1rem;
    }
    .note-title {
      font-size: clamp(1.7rem, 8vw, 2.5rem);
    }
    .post-body h2 { font-size: 1.42rem; }
    .post-body h3 { font-size: 1.2rem; }

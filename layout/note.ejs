</style>

<div class="note-shell">
  <nav class="note-dock glass-card" aria-label="Note navigation">
    <a href="<%- resolveUrl(homeMenu.url || '/') %>" class="dock-avatar" aria-label="Home">
      <img src="<%- theme.avatar || '/images/avatar-cat.svg' %>" alt="avatar">
    </a>
    <% dockLinks.forEach((item) => { %>
      <a href="<%- resolveUrl(item.url) %>" class="dock-link <%= item.active ? 'is-active' : '' %>" aria-label="<%- item.label %>" title="<%- item.label %>">
        <i class="<%- item.icon %>"></i>
      </a>
    <% }) %>
  </nav>

  <section class="note-status glass-card" aria-label="Note summary">
    <strong><%- page.title %></strong>
    <span><%- noteStatusLabel %></span>
    <small><%- noteCountSummary %></small>
  </section>

  <div class="note-grid">
    <main class="note-main">
      <section class="glass-card note-hero note-panel">
        <span class="note-kicker"><i class="fa-regular fa-note-sticky"></i><%- noteKicker %></span>
        <h1 class="note-title"><%- page.title %></h1>
        <% if (noteSummary) { %>
          <p class="note-summary"><%- noteSummary %></p>
        <% } %>
        <div class="note-meta">
          <% if (noteDate) { %><span class="note-pill"><i class="fa-regular fa-calendar"></i><%- noteDate %></span><% } %>
          <% if (showUpdated) { %><span class="note-pill"><i class="fa-solid fa-rotate"></i>Updated <%- noteUpdated %></span><% } %>
          <span class="note-pill"><i class="fa-regular fa-file-lines"></i><%- noteWordCountLabel %></span>
          <% categories.forEach((item) => { %><a href="<%- url_for(item.path) %>" class="note-chip"><i class="fa-solid fa-folder-open"></i><%- item.name %></a><% }) %>
          <% tags.forEach((item) => { %><a href="<%- url_for(item.path) %>" class="note-chip"><i class="fa-solid fa-hashtag"></i><%- item.name %></a><% }) %>
        </div>
        <div class="note-actions">
          <a href="<%- resolveUrl(noteBackUrl) %>" class="note-action"><i class="fa-solid fa-arrow-left"></i><span><%- noteBackLabel %></span></a>
          <a href="<%- resolveUrl(noteArchiveUrl) %>" class="note-action"><span><%- noteArchiveLabel %></span><i class="fa-solid fa-arrow-right"></i></a>
        </div>
        <% if (noteShowCover && noteCover) { %>
          <div class="note-cover"><img src="<%- noteCover %>" alt="<%- page.title %>" loading="lazy"></div>
        <% } %>
      </section>

      <article class="glass-card note-panel note-reading-panel">
        <div class="post-body"><%- page.content %></div>
      </article>
    </main>
  </div>
</div>

<nav class="note-floating-toc toc-box style-1" data-note-floating-toc aria-label="Table of contents" aria-hidden="true">
  <div class="toc-header">
    <div class="toc-title-wrap">
      <i class="fa-solid fa-list"></i>
      <span>目录</span>
    </div>
    <div class="toc-percent" data-toc-percent>0%</div>
  </div>
  <ul class="toc-list" data-toc-list></ul>
</nav>

<script>
  (() => {
    const postBody = document.querySelector('.post-body');
    const noteReadingPanel = document.querySelector('.note-reading-panel');
    const tocPanel = document.querySelector('[data-note-floating-toc]');
    if (!postBody || !noteReadingPanel || !tocPanel) return;

    const tocList = tocPanel.querySelector('[data-toc-list]');
    const tocPercent = tocPanel.querySelector('[data-toc-percent]');
    const headings = Array.from(postBody.querySelectorAll('h2, h3, h4'))
      .filter((heading) => heading.textContent && heading.textContent.trim());

    const slugHistory = new Map();
    const usedIds = new Set();
    const slugify = (value) => {
      const base = String(value || '')
        .toLowerCase()
        .normalize('NFKD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9\u4e00-\u9fa5\s-]/g, '')
        .trim()
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '');
      return base || 'section';
    };

    if (!headings.length) {
      tocPanel.remove();
      return;
    }

    const tocItems = headings.map((heading) => {
      let headingId = heading.id ? String(heading.id).trim() : '';
      if (!headingId || usedIds.has(headingId)) {
        const slugBase = slugify(heading.textContent);
        const serial = (slugHistory.get(slugBase) || 0) + 1;
        slugHistory.set(slugBase, serial);
        headingId = serial === 1 ? slugBase : `${slugBase}-${serial}`;
      }
      heading.id = headingId;
      usedIds.add(headingId);
      return {
        id: headingId,
        level: Number(heading.tagName.slice(1)),
        text: heading.textContent.trim(),
        heading
      };
    });

    tocItems.forEach((item) => {
      const li = document.createElement('li');
      const link = document.createElement('a');
      li.className = `toc-entry level-${item.level}`;
      link.className = 'toc-item';
      if (item.level === 3) link.classList.add('indent-1');
      if (item.level >= 4) link.classList.add('indent-2');
      link.href = `#${item.id}`;
      link.dataset.tocTarget = item.id;
      link.textContent = item.text;
      li.appendChild(link);
      tocList.appendChild(li);
    });

    const links = Array.from(tocList.querySelectorAll('.toc-item'));
    const getScrollOffset = () => window.scrollY || window.pageYOffset || document.documentElement.scrollTop || 0;
    const getAbsoluteTop = (element) => getScrollOffset() + element.getBoundingClientRect().top;

    const updateProgress = () => {
      if (!tocPercent) return;
      const currentOffset = getScrollOffset();
      const bodyTop = getAbsoluteTop(postBody);
      const progressStart = bodyTop - window.innerHeight * 0.18;
      const progressEnd = bodyTop + postBody.offsetHeight - window.innerHeight * 0.62;
      const distance = Math.max(progressEnd - progressStart, 1);
      const raw = ((currentOffset - progressStart) / distance) * 100;
      tocPercent.textContent = `${Math.max(0, Math.min(100, Math.round(raw)))}%`;
    };

    const updateVisibility = () => {
      if (window.innerWidth <= 1320) {
        tocPanel.classList.remove('is-visible');
        tocPanel.setAttribute('aria-hidden', 'true');
        return false;
      }
      const currentOffset = getScrollOffset();
      const readingTop = getAbsoluteTop(noteReadingPanel);
      const bodyTop = getAbsoluteTop(postBody);
      const showAfter = Math.max(0, readingTop - window.innerHeight * 0.22);
      const hideAfter = bodyTop + postBody.offsetHeight - window.innerHeight * 0.42;
      const visible = currentOffset >= showAfter && currentOffset <= hideAfter;
      tocPanel.classList.toggle('is-visible', visible);
      tocPanel.setAttribute('aria-hidden', visible ? 'false' : 'true');
      return visible;
    };

    let activeId = '';
    const updateActiveLink = () => {
      const currentOffset = getScrollOffset();
      const threshold = currentOffset + window.innerHeight * 0.24;
      let activeItem = tocItems[0];
      tocItems.forEach((item) => {
        const top = currentOffset + item.heading.getBoundingClientRect().top;
        if (top <= threshold) activeItem = item;
      });
      if (activeId === activeItem.id) return;
      activeId = activeItem.id;
      links.forEach((link) => {
        const isActive = link.dataset.tocTarget === activeItem.id;
        link.classList.toggle('active', isActive);
        if (isActive) {
          link.setAttribute('aria-current', 'true');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    };

    const refreshTocState = () => {
      updateProgress();
      const visible = updateVisibility();
      if (visible) updateActiveLink();
    };

    tocList.addEventListener('click', (event) => {
      const link = event.target.closest('.toc-item');
      if (!link) return;
      const target = document.getElementById(link.dataset.tocTarget || '');
      if (!target) return;
      event.preventDefault();
      const top = getScrollOffset() + target.getBoundingClientRect().top - 92;
      window.history.replaceState(null, '', `#${target.id}`);
      window.scrollTo({ top, behavior: 'smooth' });
    });

    let ticking = false;
    const requestRefresh = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(() => {
        ticking = false;
        refreshTocState();
      });
    };

    requestRefresh();
    window.addEventListener('scroll', requestRefresh, { passive: true });
    window.addEventListener('resize', requestRefresh);
  })();
</script>

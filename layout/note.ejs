    position: relative;
    font-weight: 700;
  }
  .note-floating-toc .toc-item.active::before {
    content: "";
    position: absolute;
    left: 0;
    top: 10%;
    width: 3px;
    height: 80%;
    background: #0ea5e9;
    border-radius: 0 4px 4px 0;

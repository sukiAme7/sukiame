<%
const toArray = (collection) => {
  if (!collection) return [];
  if (Array.isArray(collection)) return collection;
  if (typeof collection.toArray === 'function') return collection.toArray();
  return [];
};
const categories = toArray(page.categories);
const tags = toArray(page.tags);
const photoWallConfig = theme.photo_wall || {};
const guestbookConfig = theme.guestbook || {};
const friendsConfig = theme.friends || {};
const noteConfig = theme.notes && typeof theme.notes === 'object'
  ? theme.notes
  : (theme.note && typeof theme.note === 'object' ? theme.note : {});
const resolveUrl = (value) => {
  const link = value || '#';
  return /^(?:[a-z][a-z0-9+.-]*:)?\/\//i.test(link) || /^(#|mailto:|tel:)/i.test(link) ? link : url_for(link);
};
const getEntry = (group, key) => {
  const source = group && group[key] ? group[key] : {};
  return typeof source === 'string' ? { url: source } : source;
};
const toPlainText = (value) => String(value || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
const countWords = (value) => {
  const text = toPlainText(value).replace(/&[a-z0-9#]+;/gi, ' ');
  if (!text) return 0;
  const cjkCount = (text.match(/[\u3400-\u4dbf\u4e00-\u9fff\uf900-\ufaff]/g) || []).length;
  const latinCount = text
    .replace(/[\u3400-\u4dbf\u4e00-\u9fff\uf900-\ufaff]/g, ' ')
    .split(/[\s.,!?;:()[\]{}\"'`~<>/@#$%^&*_+=|\\-]+/)
    .filter(Boolean)
    .length;
  return cjkCount + latinCount;
};
const formatCount = (value) => value >= 10000 ? `${Math.round(value / 1000)}k` : value >= 1000 ? `${(value / 1000).toFixed(1).replace(/\.0$/, '')}k` : `${value}`;
const pickValue = (...values) => {
  for (const value of values) {
    if (value !== undefined && value !== null && value !== '') return value;
  }
  return '';
};
const getCover = (post) => {
  const photo = Array.isArray(post.photos) && post.photos.length ? post.photos[0] : '';
  const raw = post.cover || post.thumbnail || post.banner || post.top_img || photo || '';
  if (!raw) return '';
  const value = typeof raw === 'string' ? raw : (raw.path || raw.url || '');
  return value ? resolveUrl(value) : '';
};
const noteWordCount = countWords(page.content || '');
const noteWordCountLabel = `${formatCount(noteWordCount)} Words`;
const noteDate = page.date ? date(page.date, 'YYYY.MM.DD') : '';
const noteUpdated = page.updated ? date(page.updated, 'YYYY.MM.DD') : '';
const showUpdated = noteUpdated && noteUpdated !== noteDate;
const noteSummaryRaw = pickValue(page.note_summary, page.description, toPlainText(page.excerpt || ''));
const noteSummary = noteSummaryRaw ? noteSummaryRaw.slice(0, 220) : '';
const noteCover = getCover(page);
const noteShowCover = page.note_cover === true || noteConfig.show_cover === true;
const homeMenu = getEntry(theme.menu, 'Home');
const archiveMenu = getEntry(theme.menu, 'Archives');
const guestbookMenu = getEntry(theme.menu, 'Guestbook');
const friendsMenu = getEntry(theme.menu, 'Friends');
const noteBackUrl = pickValue(page.note_back_url, noteConfig.back_url, friendsMenu.url, friendsConfig.url, '/friends/');
const noteBackLabel = pickValue(page.note_back_label, noteConfig.back_label, friendsMenu.label, friendsConfig.title, 'Friends');
const noteArchiveUrl = pickValue(page.note_archive_url, noteConfig.archive_url, archiveMenu.url, '/archives/');
const noteArchiveLabel = pickValue(page.note_archive_label, noteConfig.archive_label, archiveMenu.label, 'Blog');
const noteKicker = pickValue(page.note_kicker, noteConfig.kicker, 'Study Note');
const noteStatusLabel = pickValue(page.note_status, noteConfig.status, 'Focused Reading');
const noteCountSummary = `${categories.length} Categories / ${tags.length} Tags / ${noteWordCountLabel}`;
const dockLinks = [
  { label: homeMenu.label || 'Home', url: homeMenu.url || '/', icon: homeMenu.icon || 'fa-solid fa-house' },
  { label: noteArchiveLabel, url: noteArchiveUrl, icon: archiveMenu.icon || 'fa-solid fa-feather-pointed' },
  noteBackUrl ? { label: noteBackLabel, url: noteBackUrl, icon: friendsMenu.icon || (friendsConfig.icon || 'fa-solid fa-link'), active: true } : null,
  photoWallConfig.url ? { label: photoWallConfig.title || 'Photo Wall', url: photoWallConfig.url, icon: photoWallConfig.icon || 'fa-solid fa-image' } : null,
  guestbookMenu.url && guestbookMenu.url !== '#' ? { label: guestbookMenu.label || 'Guestbook', url: guestbookMenu.url, icon: guestbookMenu.icon || guestbookConfig.icon || 'fa-solid fa-message' } : null
].filter(Boolean);

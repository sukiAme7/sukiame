<%
const toArray = (collection) => {
  if (!collection) return [];
  if (Array.isArray(collection)) return collection;
  if (typeof collection.toArray === 'function') return collection.toArray();
  return [];
};
const categories = toArray(page.categories);
const tags = toArray(page.tags);
const photoWallConfig = theme.photo_wall || {};
const guestbookConfig = theme.guestbook || {};
const resolveUrl = (value) => { const link = value || '#'; return /^(?:[a-z][a-z0-9+.-]*:)?\/\//i.test(link) || /^(#|mailto:|tel:)/i.test(link) ? link : url_for(link); };
const getEntry = (group, key) => { const source = group && group[key] ? group[key] : {}; return typeof source === 'string' ? { url: source } : source; };
const homeMenu = getEntry(theme.menu, 'Home');
const archiveMenu = getEntry(theme.menu, 'Archives');
const guestbookMenu = getEntry(theme.menu, 'Guestbook');
const dockLinks = [
  { label: homeMenu.label || 'Home', url: homeMenu.url || '/', icon: homeMenu.icon || 'fa-solid fa-house' },
  { label: archiveMenu.label || 'Blog', url: archiveMenu.url || '/archives/', icon: archiveMenu.icon || 'fa-solid fa-feather-pointed', active: true },
  photoWallConfig.url ? { label: photoWallConfig.title || 'Photo Wall', url: photoWallConfig.url, icon: photoWallConfig.icon || 'fa-solid fa-image' } : null,
  guestbookMenu.url && guestbookMenu.url !== '#' ? { label: guestbookMenu.label || 'Guestbook', url: guestbookMenu.url, icon: guestbookMenu.icon || guestbookConfig.icon || 'fa-solid fa-message' } : null
].filter(Boolean);
%>
<style>
  .post-shell{position:relative;min-height:100vh;padding:1rem;overflow:hidden}.post-shell::before,.post-shell::after{content:"";position:absolute;inset:-12%;pointer-events:none}.post-shell::before{background:radial-gradient(circle at 14% 16%,rgba(255,255,255,.6),rgba(255,255,255,0) 22%),radial-gradient(circle at 14% 84%,rgba(125,211,252,.22),rgba(125,211,252,0) 20%),radial-gradient(circle at 76% 80%,rgba(134,239,172,.22),rgba(134,239,172,0) 20%);filter:blur(18px);opacity:.96}.post-shell::after{background:linear-gradient(180deg,rgba(255,255,255,.22),rgba(255,255,255,.08))}
  .post-dock,.post-status{position:absolute;z-index:20}.post-dock{top:1rem;left:1rem;padding:.6rem .75rem;display:inline-flex;align-items:center;gap:.55rem}.post-status{top:1rem;right:1rem;min-width:12rem;padding:.75rem .95rem;display:flex;flex-direction:column;gap:.18rem}.post-status strong{font-size:.98rem;color:#1e293b;font-weight:800}.post-status span{font-size:.76rem;color:#64748b;font-weight:700}.post-status small{font-size:.72rem;color:#94a3b8;font-weight:700}
  .dock-avatar,.dock-link{width:2.35rem;height:2.35rem;border-radius:999px;display:inline-flex;align-items:center;justify-content:center;background:rgba(255,255,255,.66);color:#64748b;box-shadow:0 6px 18px rgba(148,163,184,.12);transition:transform .25s ease,background .25s ease,color .25s ease}.dock-avatar img{width:1.8rem;height:1.8rem;border-radius:999px;object-fit:cover}.dock-link:hover,.dock-avatar:hover{transform:translateY(-2px);background:rgba(255,255,255,.82)}.dock-link.is-active{background:rgba(255,255,255,.84);color:#38bdf8}
  .post-grid{position:relative;z-index:1;width:min(1180px,100%);margin:0 auto;padding-top:5.2rem;display:grid;grid-template-columns:minmax(0,2fr) minmax(18rem,.92fr);gap:1.5rem;align-items:start}.post-main,.post-side{display:flex;flex-direction:column;gap:1.5rem}.post-hero,.post-panel{padding:1.35rem 1.4rem}
  .post-kicker{font-size:.76rem;letter-spacing:.14em;text-transform:uppercase;color:#94a3b8;font-weight:800}.post-title{margin:.65rem 0 0;font-size:clamp(1.9rem,3vw,2.7rem);line-height:1.06;color:#1e293b;font-weight:900;letter-spacing:-.03em}.post-meta{margin-top:1rem;display:flex;flex-wrap:wrap;gap:.6rem}.post-pill,.post-chip,.post-side-link{display:inline-flex;align-items:center;gap:.42rem;padding:.48rem .76rem;border-radius:999px;background:rgba(255,255,255,.56);color:#475569;font-size:.78rem;font-weight:800;box-shadow:inset 0 1px 0 rgba(255,255,255,.32)}
  .post-body{color:#334155;font-size:1rem;line-height:1.95;font-weight:600}.post-body :first-child{margin-top:0}.post-body h2,.post-body h3,.post-body h4{color:#1e293b;line-height:1.2;margin:1.9rem 0 .85rem;font-weight:900}.post-body p,.post-body ul,.post-body ol,.post-body blockquote{margin:.9rem 0}.post-body a{color:#0369a1;font-weight:800}.post-body blockquote{padding:.9rem 1rem;border-left:4px solid rgba(125,211,252,.8);background:rgba(255,255,255,.34);border-radius:.9rem;color:#475569}.post-body code{padding:.14rem .38rem;border-radius:.45rem;background:rgba(255,255,255,.58);color:#0f172a;font-size:.92em}.post-body figure.highlight{margin:1rem 0;padding:.95rem 1rem;border-radius:1rem;background:rgba(15,23,42,.92);color:#e2e8f0;overflow:auto}.post-body figure.highlight table{width:100%;border-spacing:0}.post-body figure.highlight td{vertical-align:top}.post-body figure.highlight .gutter{width:2rem;color:rgba(148,163,184,.85);user-select:none}.post-body figure.highlight pre{margin:0;font-family:Consolas,'Courier New',monospace;font-size:.92rem;line-height:1.7}
  .post-panel-title{margin:0 0 .85rem;font-size:.98rem;color:#1e293b;font-weight:900}.post-side-list{display:grid;gap:.6rem}.post-side-link{justify-content:space-between;font-size:.82rem}.post-side-link:hover{background:rgba(255,255,255,.7);transform:translateY(-2px)}.post-side-empty{color:#94a3b8;font-size:.84rem;line-height:1.8;font-weight:700}
  @media (max-width:1024px){.post-grid{grid-template-columns:1fr}} @media (max-width:768px){.post-shell{padding:1rem}.post-dock,.post-status{position:relative;top:auto;left:auto;right:auto;margin-bottom:.85rem}.post-dock{width:fit-content}.post-grid{padding-top:.2rem}} @media (max-width:640px){.post-dock{width:100%;justify-content:space-between;gap:.4rem}.dock-avatar,.dock-link{width:2.1rem;height:2.1rem}}
</style>
<div class="post-shell"><nav class="post-dock glass-card" aria-label="Post navigation"><a href="<%- resolveUrl(homeMenu.url || '/') %>" class="dock-avatar" aria-label="Home"><img src="<%- theme.avatar || '/images/avatar-cat.svg' %>" alt="avatar"></a><% dockLinks.forEach((item) => { %><a href="<%- resolveUrl(item.url) %>" class="dock-link <%= item.active ? 'is-active' : '' %>" aria-label="<%- item.label %>" title="<%- item.label %>"><i class="<%- item.icon %>"></i></a><% }) %></nav><section class="post-status glass-card" aria-label="Post summary"><strong><%- page.title %></strong><span><%- date(page.date, 'YYYY.MM.DD') %></span><small><%- `${categories.length} Categories / ${tags.length} Tags` %></small></section><div class="post-grid"><main class="post-main"><section class="glass-card post-hero"><span class="post-kicker">Blog Post</span><h1 class="post-title"><%- page.title %></h1><div class="post-meta"><span class="post-pill"><i class="fa-regular fa-calendar"></i><%- date(page.date, 'YYYY.MM.DD') %></span><% categories.forEach((item) => { %><a href="<%- url_for(item.path) %>" class="post-chip"><i class="fa-solid fa-folder-open"></i><%- item.name %></a><% }) %><% tags.forEach((item) => { %><a href="<%- url_for(item.path) %>" class="post-chip"><i class="fa-solid fa-hashtag"></i><%- item.name %></a><% }) %></div></section><article class="glass-card post-panel"><div class="post-body"><%- page.content %></div></article></main><aside class="post-side"><section class="glass-card post-panel"><h2 class="post-panel-title">Taxonomy</h2><% if (!categories.length && !tags.length) { %><div class="post-side-empty">Add `categories:` or `tags:` to this post front matter to organize it here.</div><% } else { %><div class="post-side-list"><% categories.forEach((item) => { %><a href="<%- url_for(item.path) %>" class="post-side-link"><span><i class="fa-solid fa-folder-tree"></i>&nbsp;<%- item.name %></span><span>Category</span></a><% }) %><% tags.forEach((item) => { %><a href="<%- url_for(item.path) %>" class="post-side-link"><span><i class="fa-solid fa-hashtag"></i>&nbsp;<%- item.name %></span><span>Tag</span></a><% }) %></div><% } %></section><section class="glass-card post-panel"><h2 class="post-panel-title">More</h2><div class="post-side-list"><a href="<%- url_for('/archives/') %>" class="post-side-link"><span><i class="fa-solid fa-feather-pointed"></i>&nbsp;Back To Blog</span><i class="fa-solid fa-arrow-right"></i></a><% if (page.prev) { %><a href="<%- url_for(page.prev.path) %>" class="post-side-link"><span><i class="fa-solid fa-arrow-left"></i>&nbsp;<%- page.prev.title %></span><span>Prev</span></a><% } %><% if (page.next) { %><a href="<%- url_for(page.next.path) %>" class="post-side-link"><span><%- page.next.title %>&nbsp;<i class="fa-solid fa-arrow-right"></i></span><span>Next</span></a><% } %></div></section></aside></div></div>

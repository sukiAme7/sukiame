  photoWallConfig.url ? { label: photoWallConfig.title || 'Photo Wall', url: photoWallConfig.url, icon: photoWallConfig.icon || 'fa-solid fa-image' } : null,
  guestbookMenu.url && guestbookMenu.url !== '#' ? { label: guestbookMenu.label || 'Guestbook', url: guestbookMenu.url, icon: guestbookMenu.icon || guestbookConfig.icon || 'fa-solid fa-message' } : null
].filter(Boolean);

const codeBlocksConfig = theme.code_blocks || {};
const normalizeThemeValue = String(codeBlocksConfig.theme || 'light').trim().toLowerCase();
const codeBlockTheme = ['darker', 'pale night', 'light', 'ocean', 'false'].includes(normalizeThemeValue) ? normalizeThemeValue : 'light';
const codeBlockThemeClass = codeBlockTheme === 'false' ? 'plain' : codeBlockTheme.replace(/\s+/g, '-');
const codeBlockMacStyle = !!codeBlocksConfig.macStyle;
const codeBlockHeightLimitRaw = Number(codeBlocksConfig.height_limit);
const codeBlockHeightLimit = Number.isFinite(codeBlockHeightLimitRaw) && codeBlockHeightLimitRaw > 0 ? codeBlockHeightLimitRaw : 0;
const codeBlockWordWrap = !!codeBlocksConfig.word_wrap;
const codeBlockCopy = codeBlocksConfig.copy !== false;
const codeBlockLanguage = codeBlocksConfig.language !== false;
const codeBlockShrinkMode = codeBlocksConfig.shrink === true ? 'collapsed' : (codeBlocksConfig.shrink === 'none' ? 'none' : 'expanded');

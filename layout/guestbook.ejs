        right: -0.8rem;
        width: 2.6rem;
        height: 2.6rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.9);
        color: #334155;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 14px 30px rgba(15, 23, 42, 0.16);
        transition: transform 0.2s ease, background 0.2s ease;
    }

    .guestbook-lightbox-close:hover {
        transform: translateY(-2px);
        background: #fff;
    }

    .guestbook-lightbox-head,
    .guestbook-lightbox-foot {
        position: relative;
        z-index: 1;
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        color: #334155;
    }

    .guestbook-lightbox-head {
        margin-top: 0.6rem;
        align-items: center;
    }

    .guestbook-lightbox-author {
        font-size: 1rem;
        font-weight: 900;
    }

    .guestbook-lightbox-meta {
        font-size: 0.78rem;
        font-weight: 700;
        color: rgba(51, 65, 85, 0.78);
    }

    .guestbook-lightbox-message {
        position: relative;
        z-index: 1;
        margin: 1rem 0 1.4rem;
        white-space: pre-wrap;
        font-size: 1.08rem;
        line-height: 1.9;
        color: #334155;
        font-family: 'ZCOOL KuaiLe', cursive;
    }

    .guestbook-lightbox-foot {
        font-size: 0.78rem;
        font-weight: 700;
        color: rgba(51, 65, 85, 0.76);
    }

    .guestbook-lightbox-label {
        opacity: 0.8;
    }

    @keyframes guestbookReveal {
        from {
            opacity: 0;
            transform: translate(var(--note-dx, 0px), calc(var(--note-dy, 0px) + 18px)) scale(0.94);
        }

        to {
            opacity: 1;
            transform: translate(var(--note-dx, 0px), var(--note-dy, 0px));
        }
    }

    @media (max-width: 1024px) {
        .guestbook-status {
            min-width: auto;
        }

        .guestbook-board {
            min-height: 78rem;
        }
    }

    @media (max-width: 900px) {
        .guestbook-shell {
            padding: 1rem;
        }

        .guestbook-dock,
        .guestbook-status {
            position: relative;
            top: auto;
            left: auto;
            right: auto;
            margin-bottom: 0.85rem;
        }

        .guestbook-dock {
            width: fit-content;
        }

        .guestbook-status {
            display: inline-flex;
        }

        .guestbook-board {
            min-height: auto;
            padding-top: 0.5rem;
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 1.2rem;
            align-items: start;
        }

        .sticky-note-card {
            position: relative;
            left: auto;
            top: auto;
            width: 100%;
            max-width: 16rem;
            margin: 0 auto;
        }
    }

    @media (max-width: 640px) {
        .guestbook-dock {
            width: 100%;
            justify-content: space-between;
            gap: 0.4rem;
        }

        .dock-avatar,
        .dock-link {
            width: 2.1rem;
            height: 2.1rem;
        }

        .guestbook-status {
            width: 100%;
        }

        .guestbook-board {
            grid-template-columns: 1fr;
        }

        .composer-note-card {
            position: relative;
            left: auto;
            top: auto;
            width: 100%;
            max-width: 16rem;
            margin: 0 auto;
            order: -1;
        }

        .guestbook-form-row {
            grid-template-columns: 1fr;
        }

        .guestbook-composer {
            padding: 1rem;
        }

        .guestbook-composer-dialog {
            width: 100%;
        }

        .guestbook-lightbox {
            padding: 1rem;
        }

        .guestbook-lightbox-dialog {
            width: 100%;
        }
    }
</style>

<div class="guestbook-shell">
    <h1 class="sr-only"><%- boardTitle %></h1>

    <nav class="guestbook-dock glass-card" aria-label="Guestbook navigation">
        <a href="<%- resolveUrl(homeMenu.url || '/') %>" class="dock-avatar" aria-label="Home">
            <img src="<%- theme.avatar || '/images/avatar-cat.svg' %>" alt="avatar">
        </a>
        <% dockLinks.forEach((item) => { %>
            <a
                href="<%- resolveUrl(item.url) %>"
                class="dock-link <%= item.active ? 'is-active' : '' %>"
                aria-label="<%- item.label %>"
                title="<%- item.label %>"
            >
                <i class="<%- item.icon %>"></i>
            </a>
        <% }) %>
    </nav>

    <section class="guestbook-status glass-card" aria-label="Guestbook information">
        <strong><%- boardTitle %></strong>
        <span><%- boardSubtitle %></span>
        <small id="guestbook-count"><%- `${noteItems.length} ${boardCountLabel}` %></small>
    </section>

    <main class="guestbook-board" aria-label="<%- boardNote %>">
        <article
            class="composer-note-card"
            style="--composer-left: <%- composerCard.x %>%; --composer-top: <%- composerCard.y %>%; --composer-width: <%- composerCard.width %>px; --composer-rotate: <%- composerCard.rotate %>deg; --composer-base: <%- composerToneStyle.base %>; --composer-deep: <%- composerToneStyle.deep %>; --composer-fold: <%- composerToneStyle.fold %>; --composer-shadow: <%- composerToneStyle.shadow %>;"
        >
            <section class="composer-note-paper">
                <div class="composer-note-head">
                    <strong class="composer-note-title"><%- composerCard.title %></strong>
                    <span class="composer-note-badge"><i class="fa-solid fa-pen-to-square"></i></span>
                </div>
                <p class="composer-note-copy"><%- composerCard.subtitle %></p>
                <div class="composer-note-foot">
                    <span>Visitor entry</span>
                    <button class="composer-note-button" type="button" id="open-guestbook-composer"><%- composerCard.button %></button>
                </div>
            </section>
        </article>

        <% noteItems.forEach((item) => { %>
            <article
                class="sticky-note-card"
                data-author="<%- item.author %>"
                data-date="<%- item.date %>"
                data-message="<%- item.message %>"
                data-tone="<%- item.tone %>"
                style="--note-left: <%- item.x %>%; --note-top: <%- item.y %>%; --note-width: <%- item.width %>px; --note-rotate: <%- item.rotate %>deg; --note-delay: <%- item.delay %>; --note-base: <%- item.toneStyle.base %>; --note-deep: <%- item.toneStyle.deep %>; --note-fold: <%- item.toneStyle.fold %>; --note-shadow: <%- item.toneStyle.shadow %>;"
            >
                <section class="sticky-note-paper">
                    <div class="sticky-note-head">
                        <strong class="sticky-note-author"><%- item.author %></strong>
                        <span class="sticky-note-badge"><i class="fa-solid fa-pencil"></i></span>
                    </div>
                    <p class="sticky-note-message"><%- item.message %></p>
                    <div class="sticky-note-foot">
                        <span><%- item.date %></span>
                        <span class="sticky-note-hint">double tap</span>
                    </div>
                </section>
            </article>
        <% }) %>
    </main>

    <div class="guestbook-lightbox" aria-hidden="true">
        <div class="guestbook-lightbox-dialog">
            <button class="guestbook-lightbox-close" type="button" aria-label="Close note">
                <i class="fa-solid fa-xmark"></i>
            </button>
            <article class="guestbook-lightbox-paper" style="--note-base: #fff3a8; --note-deep: #f9e485; --note-fold: #efd05f;">
                <div class="guestbook-lightbox-head">
                    <strong class="guestbook-lightbox-author"></strong>
                    <span class="guestbook-lightbox-meta"></span>
                </div>
                <div class="guestbook-lightbox-message"></div>
                <div class="guestbook-lightbox-foot">
                    <span class="guestbook-lightbox-label">Guestbook Note</span>
                    <span>double click to close</span>
                </div>
            </article>
        </div>
    </div>

    <div class="guestbook-composer" aria-hidden="true">
        <section class="guestbook-composer-dialog glass-card" aria-label="Write a guestbook note">
            <div class="guestbook-composer-head">
                <div>
                    <strong>Write A Note</strong>
                    <span>Leave a little message for the next visitor.</span>
                </div>
                <button class="guestbook-composer-close" type="button" aria-label="Close composer">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <form class="guestbook-form" id="guestbook-form">
                <div class="guestbook-form-row">
                    <div class="guestbook-field">
                        <label for="guestbook-author">Your Name</label>
                        <input class="guestbook-input" id="guestbook-author" name="author" maxlength="20" placeholder="e.g. SukiAme" required>
                    </div>
                    <div class="guestbook-field">
                        <label for="guestbook-tone">Note Color</label>
                        <select class="guestbook-select" id="guestbook-tone" name="tone">
                            <option value="yellow">Sunny Yellow</option>
                            <option value="pink">Soft Pink</option>
                            <option value="blue">Sky Blue</option>
                            <option value="green">Mint Green</option>
                            <option value="lavender">Lavender</option>
                            <option value="peach">Peach</option>
                        </select>
                    </div>
                </div>
                <div class="guestbook-field">
                    <label for="guestbook-message">Message</label>
                    <textarea class="guestbook-textarea" id="guestbook-message" name="message" maxlength="180" placeholder="Write something kind, warm, or memorable..." required></textarea>
                </div>
                <div class="guestbook-form-foot">
                    <span class="guestbook-form-hint">Your note will be saved in this browser. Shared syncing can come next.</span>
                    <button class="guestbook-submit" type="submit">Post This Note</button>
                </div>
            </form>
        </section>
    </div>
</div>

<script>
    (() => {
        const board = document.querySelector('.guestbook-board');
        if (!board) return;

        const cards = Array.from(board.querySelectorAll('.sticky-note-card'));
        if (!cards.length) return;

        const lightbox = document.querySelector('.guestbook-lightbox');
        const lightboxPaper = lightbox ? lightbox.querySelector('.guestbook-lightbox-paper') : null;
        const lightboxAuthor = lightbox ? lightbox.querySelector('.guestbook-lightbox-author') : null;
        const lightboxMeta = lightbox ? lightbox.querySelector('.guestbook-lightbox-meta') : null;
        const lightboxMessage = lightbox ? lightbox.querySelector('.guestbook-lightbox-message') : null;
        const lightboxClose = lightbox ? lightbox.querySelector('.guestbook-lightbox-close') : null;
        const composer = document.querySelector('.guestbook-composer');
        const composerOpen = document.getElementById('open-guestbook-composer');
        const composerClose = composer ? composer.querySelector('.guestbook-composer-close') : null;
        const composerForm = document.getElementById('guestbook-form');
        const countEl = document.getElementById('guestbook-count');
        const storageKey = 'sukiame:guestbook:user-notes:v1';
        const canUseStorage = (() => {
            try {
                const probeKey = `${storageKey}:probe`;
                window.localStorage.setItem(probeKey, '1');
                window.localStorage.removeItem(probeKey);
                return true;
            } catch (error) {
                return false;
            }
        })();

        const tonePalette = {
            yellow: { base: '#fff3a8', deep: '#f9e485', fold: '#efd05f', shadow: 'rgba(236, 201, 84, 0.28)' },
            pink: { base: '#ffd8df', deep: '#ffc5d0', fold: '#f2aebf', shadow: 'rgba(241, 171, 194, 0.28)' },
            blue: { base: '#d2eaff', deep: '#b9dcfb', fold: '#9dcaef', shadow: 'rgba(117, 174, 226, 0.28)' },
            green: { base: '#daf3d5', deep: '#c9ebc2', fold: '#aed8a6', shadow: 'rgba(130, 193, 127, 0.28)' },
            lavender: { base: '#e7ddff', deep: '#d8cbfb', fold: '#bba8ee', shadow: 'rgba(168, 146, 231, 0.28)' },
            peach: { base: '#ffe4cb', deep: '#ffd6b3', fold: '#f3c18f', shadow: 'rgba(237, 171, 118, 0.28)' }
        };

        let activeState = null;
        let topLayer = cards.length + 2;
        let lastTap = { card: null, time: 0 };

        const updateCount = () => {
            if (!countEl) return;
            countEl.textContent = `${board.querySelectorAll('.sticky-note-card').length} <%- boardCountLabel %>`;
        };

        const readStoredNotes = () => {
            if (!canUseStorage) return [];

            try {
                const raw = window.localStorage.getItem(storageKey);
                if (!raw) return [];
                const parsed = JSON.parse(raw);
                return Array.isArray(parsed) ? parsed : [];
            } catch (error) {
                return [];
            }
        };

        const persistUserNotes = () => {
            if (!canUseStorage) return;

            const notes = Array.from(board.querySelectorAll('.sticky-note-card[data-user-note="true"]')).map((card) => ({
                id: card.dataset.noteId || '',
                author: card.dataset.author || '',
                date: card.dataset.date || '',
                message: card.dataset.message || '',
                tone: card.dataset.tone || 'yellow',
                left: card.style.getPropertyValue('--note-left') || '',
                top: card.style.getPropertyValue('--note-top') || '',
                width: card.style.getPropertyValue('--note-width') || '',
                rotate: card.style.getPropertyValue('--note-rotate') || '',
                dx: Number(card.dataset.dx || 0),
                dy: Number(card.dataset.dy || 0)
            }));

            try {
                window.localStorage.setItem(storageKey, JSON.stringify(notes));
            } catch (error) {
                /* noop */
            }
        };

        const escapeHtml = (value) => String(value)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');

        const applyOffset = (card, dx, dy) => {
            card.dataset.dx = String(dx);
            card.dataset.dy = String(dy);
            card.style.setProperty('--note-dx', `${dx}px`);
            card.style.setProperty('--note-dy', `${dy}px`);
        };

        const openComposer = () => {
            if (!composer) return;
            composer.classList.add('is-open');
            composer.setAttribute('aria-hidden', 'false');
            document.body.classList.add('guestbook-composer-open');
        };

        const closeComposer = () => {
            if (!composer || !composer.classList.contains('is-open')) return;
            composer.classList.remove('is-open');
            composer.setAttribute('aria-hidden', 'true');
            document.body.classList.remove('guestbook-composer-open');
        };

        const openLightbox = (card) => {
            if (!lightbox || !lightboxPaper) return;

            const tone = tonePalette[card.dataset.tone] || tonePalette.yellow;
            lightboxPaper.style.setProperty('--note-base', tone.base);
            lightboxPaper.style.setProperty('--note-deep', tone.deep);
            lightboxPaper.style.setProperty('--note-fold', tone.fold);

            if (lightboxAuthor) lightboxAuthor.textContent = card.dataset.author || '';
            if (lightboxMeta) lightboxMeta.textContent = card.dataset.date || '';
            if (lightboxMessage) lightboxMessage.textContent = card.dataset.message || '';

            lightbox.classList.add('is-open');
            lightbox.setAttribute('aria-hidden', 'false');
            document.body.classList.add('guestbook-lightbox-open');
        };

        const closeLightbox = () => {
            if (!lightbox || !lightbox.classList.contains('is-open')) return;

            lightbox.classList.remove('is-open');
            lightbox.setAttribute('aria-hidden', 'true');
            document.body.classList.remove('guestbook-lightbox-open');
        };

        const registerCard = (card, indexHint) => {
            applyOffset(card, Number(card.dataset.dx || 0), Number(card.dataset.dy || 0));
            card.style.zIndex = String(indexHint || ++topLayer);

            card.addEventListener('dragstart', (event) => {
                event.preventDefault();
            });

            card.addEventListener('pointerdown', (event) => {
                if (event.pointerType === 'mouse' && event.button !== 0) return;

                activeState = {
                    card,
                    pointerId: event.pointerId,
                    pointerType: event.pointerType,
                    startX: event.clientX,
                    startY: event.clientY,
                    startDx: parseFloat(card.dataset.dx || '0'),
                    startDy: parseFloat(card.dataset.dy || '0'),
                    moved: false
                };

                topLayer += 1;
                card.style.zIndex = String(topLayer);
                card.classList.add('is-dragging');

                if (card.setPointerCapture) {
                    card.setPointerCapture(event.pointerId);
                }

                event.preventDefault();
            });

            card.addEventListener('dblclick', (event) => {
                event.preventDefault();
                openLightbox(card);
            });
        };

        cards.forEach((card, index) => {
            registerCard(card, index + 1);
        });

        const createNoteCard = (payload, options = {}) => {
            const {
                id,
                author,
                date,
                message,
                tone,
                left,
                top,
                width,
                rotate,
                dx = 0,
                dy = 0
            } = payload;
            const { persist = true } = options;
            const toneStyle = tonePalette[tone] || tonePalette.yellow;
            const safeAuthor = escapeHtml(author);
            const safeMessage = escapeHtml(message);
            const card = document.createElement('article');
            const boardWidth = board.clientWidth || 1200;
            const boardHeight = board.clientHeight || 900;
            const computedWidth = Math.max(198, Math.min(220, Math.round(boardWidth * 0.18)));
            const noteWidth = typeof width === 'number' ? width : parseInt(width || `${computedWidth}`, 10) || computedWidth;
            const maxX = Math.max(32, boardWidth - noteWidth - 32);
            const maxY = Math.max(120, boardHeight - 240);
            const randomX = Math.round(24 + Math.random() * maxX);
            const randomY = Math.round(110 + Math.random() * maxY);
            const randomRotate = Math.round((Math.random() * 18) - 9);
            const today = new Date();
            const displayDate = date || `${today.getFullYear()}.${String(today.getMonth() + 1).padStart(2, '0')}.${String(today.getDate()).padStart(2, '0')}`;
            const leftValue = left || `${randomX}px`;
            const topValue = top || `${randomY}px`;
            const rotateValue = typeof rotate === 'number'
                ? `${rotate}deg`
                : (rotate || `${randomRotate}deg`);
            const noteId = id || `guest-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;

            card.className = 'sticky-note-card';
            card.dataset.userNote = 'true';
            card.dataset.noteId = noteId;
            card.dataset.author = author;
            card.dataset.date = displayDate;
            card.dataset.message = message;
            card.dataset.tone = tone;
            card.dataset.dx = String(Number(dx || 0));
            card.dataset.dy = String(Number(dy || 0));
            card.style.setProperty('--note-left', leftValue);
            card.style.setProperty('--note-top', topValue);
            card.style.setProperty('--note-width', `${noteWidth}px`);
            card.style.setProperty('--note-rotate', rotateValue);
            card.style.setProperty('--note-delay', '0');
            card.style.setProperty('--note-base', toneStyle.base);
            card.style.setProperty('--note-deep', toneStyle.deep);
            card.style.setProperty('--note-fold', toneStyle.fold);
            card.style.setProperty('--note-shadow', toneStyle.shadow);
            card.innerHTML = `
                <section class="sticky-note-paper">
                    <div class="sticky-note-head">
                        <strong class="sticky-note-author">${safeAuthor}</strong>
                        <span class="sticky-note-badge"><i class="fa-solid fa-pencil"></i></span>
                    </div>
                    <p class="sticky-note-message">${safeMessage}</p>
                    <div class="sticky-note-foot">
                        <span>${displayDate}</span>
                        <span class="sticky-note-hint">double tap</span>
                    </div>
                </section>
            `;

            board.appendChild(card);
            registerCard(card);
            if (dx || dy) {
                applyOffset(card, Number(dx || 0), Number(dy || 0));
            }
            updateCount();
            if (persist) {
                persistUserNotes();
            }
            return card;
        };

        const handleMove = (event) => {
            if (!activeState || activeState.pointerId !== event.pointerId) return;

            const dx = activeState.startDx + (event.clientX - activeState.startX);
            const dy = activeState.startDy + (event.clientY - activeState.startY);

            if (Math.abs(dx - activeState.startDx) > 6 || Math.abs(dy - activeState.startDy) > 6) {
                activeState.moved = true;
            }

            applyOffset(activeState.card, dx, dy);
        };

        const finishDrag = (event) => {
            if (!activeState || (event && activeState.pointerId !== event.pointerId)) return;

            const { card, pointerId, pointerType, moved } = activeState;
            card.classList.remove('is-dragging');

            if (card.releasePointerCapture) {
                try {
                    card.releasePointerCapture(pointerId);
                } catch (error) {
                    /* noop */
                }
            }

            if (!moved && pointerType !== 'mouse') {
                const now = Date.now();
                if (lastTap.card === card && now - lastTap.time < 320) {
                    openLightbox(card);
                    lastTap = { card: null, time: 0 };
                } else {
                    lastTap = { card, time: now };
                }
            }

            if (card.dataset.userNote === 'true') {
                persistUserNotes();
            }

            activeState = null;
        };

        if (lightbox) {
            lightbox.addEventListener('click', (event) => {
                if (event.target === lightbox || event.target === lightboxClose) {
                    closeLightbox();
                }
            });

            lightbox.addEventListener('dblclick', closeLightbox);
        }

        if (lightboxClose) {
            lightboxClose.addEventListener('click', closeLightbox);
        }

        if (composerOpen) {
            composerOpen.addEventListener('click', openComposer);
        }

        if (composer) {
            composer.addEventListener('click', (event) => {
                if (event.target === composer) {
                    closeComposer();
                }
            });
        }

        if (composerClose) {
            composerClose.addEventListener('click', closeComposer);
        }

        if (composerForm) {
            composerForm.addEventListener('submit', (event) => {
                event.preventDefault();

                const formData = new FormData(composerForm);
                const author = String(formData.get('author') || '').trim();
                const message = String(formData.get('message') || '').trim();
                const tone = String(formData.get('tone') || 'yellow');

                if (!author || !message) return;

                createNoteCard({ author, message, tone });
                composerForm.reset();
                closeComposer();
            });
        }

        readStoredNotes().forEach((item) => {
            createNoteCard(item, { persist: false });
        });

        window.addEventListener('pointermove', handleMove);
        window.addEventListener('pointerup', finishDrag);
        window.addEventListener('pointercancel', finishDrag);
        window.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
                closeLightbox();
                closeComposer();
            }
        });

        updateCount();
    })();
</script>
